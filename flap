# _drv_advisories DRIVER_NAME DRIVER_VER FIRMWARE_VER IFACE
# Prints zero or more lines: LEVEL<TAB>Title<TAB>Description<TAB>Fix<TAB>SourceURL
# Each line is a known advisory for the given driver, sourced from official documentation.
_drv_advisories() {
  local drv="$1" iface="${4:-IFACE}"
  case "$drv" in
    r8169)
      printf 'WARN\t%s\t%s\t%s\t%s\n' \
        "Driver advisory — r8169 (Realtek)" \
        "r8169 has well-documented EEE negotiation and link-stability issues with many switch vendors. Realtek distributes an alternative out-of-tree driver (r8168) with improved stability." \
        "Disable EEE: ethtool --set-eee ${iface} eee off  — or install r8168 from Realtek" \
        "https://www.realtek.com/en/component/zoo/category/network-interface-controllers-10-100-1000m-gigabit-ethernet-pci-express-software"
      ;;
    tg3)
      printf 'WARN\t%s\t%s\t%s\t%s\n' \
        "Driver advisory — tg3 (Broadcom/Tigon3)" \
        "tg3 EEE (green ethernet) negotiation is documented to cause link drops with certain switch vendors. The kernel tg3 documentation lists EEE as a known interoperability concern." \
        "Disable EEE: ethtool --set-eee ${iface} eee off" \
        "https://www.kernel.org/doc/html/latest/networking/device_drivers/ethernet/broadcom/tg3.html"
      ;;
    virtio_net)
      printf 'INFO\t%s\t%s\t%s\t%s\n' \
        "Driver note — virtio_net (virtual NIC)" \
        "virtio_net link events are generated by the hypervisor. Live VM migrations and hypervisor pause events appear as link flaps and are expected behaviour, not hardware faults." \
        "Check hypervisor migration/event logs for the VM; correlate flap timestamps with migration events" \
        "https://www.qemu.org/docs/master/devel/migration.html"
      ;;
    bnxt_en)
      printf 'WARN\t%s\t%s\t%s\t%s\n' \
        "Driver advisory — bnxt_en (Broadcom NetXtreme)" \
        "Older bnxt_en firmware versions have known link-stability issues. Broadcom provides updated firmware and driver release notes documenting fixed defects per NIC model." \
        "Check current firmware: ethtool -i ${iface}; update from Broadcom support" \
        "https://docs.broadcom.com/"
      ;;
    sfc)
      printf 'WARN\t%s\t%s\t%s\t%s\n' \
        "Driver advisory — sfc (Solarflare/AMD Xilinx)" \
        "Some sfc firmware versions have intermittent link-stability issues triggered by flow-control mismatches. AMD/Xilinx publishes per-firmware-version release notes documenting resolved defects." \
        "Disable flow control: ethtool -A ${iface} autoneg off rx off tx off; update sfc firmware" \
        "https://docs.amd.com/"
      ;;
    cdc_ncm|cdc_ether|cdc_mbim)
      printf 'WARN\t%s\t%s\t%s\t%s\n' \
        "Driver note — ${drv} (USB CDC Ethernet)" \
        "cdc_ncm/cdc_ether/cdc_mbim are USB-attached Ethernet adapters. High RX drop counts are typically caused by USB NCM aggregation limits, URB pool exhaustion, or USB host-controller bandwidth contention — not the Ethernet cable. The firmware-version field reflects the kernel version string, which is normal for this driver. CDC Status OK confirms the USB control channel is healthy; it does not guarantee the data path is drop-free. Swapping the Ethernet cable or switch port will not resolve drops that originate in the USB subsystem." \
        "1. Check NCM parameters: cat /sys/module/cdc_ncm/parameters/*  2. Check USB errors: dmesg | grep -iE 'cdc_ncm|xhci|ehci|usb.*error|usb.*reset'  3. Try a different USB host port (different root hub, not just a different socket on the same hub)  4. Inspect the USB path for intermediate hubs: udevadm info --query=path /sys/class/net/${iface}  5. If drops persist across all USB ports: replace the USB Ethernet adapter itself" \
        "https://www.kernel.org/doc/html/latest/networking/cdc_ncm.html"
      ;;
  esac
}

run_wizard() {
  local iface="$1"
  mkdir -p "$BACKUP_DIR" "$REPORT_DIR"

  # 1. Create backup
  local backup_id
  backup_id=$(create_backup "$iface")

  # 2. Validate interface (skipped in test mode)
  if [[ -z "${_LINK_FLAP_TEST_WIZARD_DIR:-}" ]]; then
    if ! ip link show "$iface" &>/dev/null; then
      echo "Error: interface '$iface' not found." >&2; exit 1
    fi
  fi

  # 3. Collect diagnostic data
  local operstate carrier_changes power_control
  local ethtool_out ethtool_s_out ethtool_eee_out ip_link_out dmesg_raw dmesg_out

  operstate=$(_wiz_read "/sys/class/net/${iface}/operstate")
  carrier_changes=$(_wiz_read "/sys/class/net/${iface}/carrier_changes")
  power_control=$(_wiz_cmd power_control cat "/sys/class/net/${iface}/device/power/control")
  ethtool_out=$(_wiz_cmd ethtool ethtool "$iface")
  ethtool_s_out=$(_wiz_cmd ethtool_s ethtool -S "$iface")
  ethtool_eee_out=$(_wiz_cmd ethtool_eee ethtool --show-eee "$iface")
  ip_link_out=$(_wiz_cmd ip_link ip link show "$iface")
  dmesg_raw=$(_wiz_cmd dmesg dmesg)
  dmesg_out=$(echo "$dmesg_raw" | grep -i "$iface" | tail -30 2>/dev/null || true)

  # Fault localization data
  local ethtool_i_out ip_addr_out ip_route_out all_links_out resolv_conf_out
  ethtool_i_out=$(_wiz_cmd ethtool_i ethtool -i "$iface")
  ip_addr_out=$(_wiz_cmd ip_addr ip addr show "$iface")
  ip_route_out=$(_wiz_cmd ip_route ip route show)
  all_links_out=$(_wiz_cmd all_links ip link show)
  resolv_conf_out=$(_wiz_cmd resolv_conf cat /etc/resolv.conf)

  # DUT interface data (only when --dut is set)
  local dut_carrier_changes="" dut_operstate="" dut_speed=""
  if [[ -n "$DUT_IFACE" ]]; then
    dut_carrier_changes=$(_wiz_read_dut "/sys/class/net/${DUT_IFACE}/carrier_changes")
    dut_operstate=$(_wiz_read_dut "/sys/class/net/${DUT_IFACE}/operstate")
    local dut_ethtool_out
    dut_ethtool_out=$(_wiz_cmd_dut dut_ethtool ethtool "$DUT_IFACE")
    dut_speed=$(echo "$dut_ethtool_out" | grep -i "Speed:" | awk '{print $2}' | head -1 || true)
  fi

  # node_exporter metrics — uses _NE_METRICS_CACHE (fetch_node_exporter called at Step 3 entry)
  local ne_up ne_rx_err ne_tx_err ne_rx_drop ne_tx_drop ne_tx_packets ne_rx_packets
  ne_up=$(_ne_val node_network_up "$iface")
  ne_rx_err=$(_ne_val node_network_receive_errs_total "$iface")
  ne_tx_err=$(_ne_val node_network_transmit_errs_total "$iface")
  ne_rx_drop=$(_ne_val node_network_receive_drop_total "$iface")
  ne_tx_drop=$(_ne_val node_network_transmit_drop_total "$iface")
  ne_tx_packets=$(_ne_val node_network_transmit_packets_total "$iface")
  ne_rx_packets=$(_ne_val node_network_receive_packets_total "$iface")

  # iperf3 active probe — uses _IPERF3_RESULT_CACHE (run_iperf3 called at Step 3 entry)
  local iperf3_bps iperf3_retransmits
  iperf3_bps=$(_iperf3_val "end.sum_sent.bits_per_second")
  iperf3_retransmits=$(_iperf3_val "end.sum_sent.retransmits")

  local speed duplex autoneg
  speed=$(echo "$ethtool_out" | grep -i "Speed:" | awk '{print $2}' | head -1 || true)
  duplex=$(echo "$ethtool_out" | grep -i "Duplex:" | awk '{print $2}' | head -1 || true)
  autoneg=$(echo "$ethtool_out" | grep -i "Auto-negotiation:" | awk '{print $2}' | head -1 || true)

  # SFP DOM (Digital Optical Monitoring) — silent on copper / unsupported NICs
  local dom_out rx_power_dbm="" tx_power_dbm=""
  dom_out=$(_wiz_cmd ethtool_m ethtool -m "$iface")
  if [[ -n "$dom_out" ]]; then
    rx_power_dbm=$(echo "$dom_out" \
      | grep -i "receiver signal\|rx power" \
      | grep -oP '[-]?[0-9]+\.[0-9]+(?= dBm)' \
      | head -1 || true)
    tx_power_dbm=$(echo "$dom_out" \
      | grep -i "laser output power\|tx power" \
      | grep -oP '[-]?[0-9]+\.[0-9]+(?= dBm)' \
      | head -1 || true)
  fi

  # LLDP neighbour — silent if lldpctl not installed
  local lldp_peer_name="" lldp_peer_port="" _lldp_available=0
  if command -v lldpctl &>/dev/null; then
    _lldp_available=1
    local lldp_raw
    lldp_raw=$(_wiz_cmd lldpctl lldpctl "$iface")
    lldp_peer_name=$(echo "$lldp_raw" | awk -F'SysName:' 'NF>1{gsub(/^[ \t]+/,"",$2); print $2; exit}')
    lldp_peer_port=$(echo "$lldp_raw" | awk -F'PortDescr:' 'NF>1{gsub(/^[ \t]+/,"",$2); print $2; exit}')
  fi

  # USB NIC detection — resolve the device symlink; if it passes through a USB bus
  # the interface is USB-attached (cdc_ncm, cdc_ether, asix, etc.).
  # In test mode, the fixture file 'iface_usb_path' overrides the live sysfs lookup.
  local _iface_usb_path="" _iface_is_usb=0
  if [[ -n "${_LINK_FLAP_TEST_WIZARD_DIR:-}" ]]; then
    _iface_usb_path=$(cat "${_LINK_FLAP_TEST_WIZARD_DIR}/iface_usb_path" 2>/dev/null || true)
  elif [[ -L "/sys/class/net/${iface}/device" ]]; then
    _iface_usb_path=$(readlink -f "/sys/class/net/${iface}/device" 2>/dev/null || true)
  fi
  [[ "$_iface_usb_path" == *"/usb"* ]] && _iface_is_usb=1

  # If USB NIC: collect USB kernel events and cdc_ncm module parameters
  local usb_dmesg_out="" ncm_params_out=""
  if [[ "$_iface_is_usb" -eq 1 ]]; then
    usb_dmesg_out=$(_wiz_cmd usb_dmesg \
      sh -c "dmesg | grep -iE 'cdc_ncm|cdc_ether|xhci|ehci|usb.*error|usb.*reset|usb.*disconnect' | tail -30")
    if [[ -d /sys/module/cdc_ncm/parameters ]]; then
      ncm_params_out=$(for _p in /sys/module/cdc_ncm/parameters/*; do
        printf '%s=%s\n' "$(basename "$_p")" "$(cat "$_p" 2>/dev/null)"
      done)
    fi
  fi

  # 4. Build findings array — each entry: "LEVEL<tab>Title<tab>Description<tab>Fix"
  local -a findings=()

  # Carrier instability — two severity tiers
  if [[ -n "$carrier_changes" ]] && [[ "$carrier_changes" =~ ^[0-9]+$ ]]; then
    if [[ "$carrier_changes" -gt 500 ]]; then
      findings+=("CAUSE"$'\t'"Severe carrier instability"$'\t'"${carrier_changes} link state transitions since boot (cumulative). A healthy, stable link has 1–5 total changes across its entire lifetime (initial autoneg + planned reboots). 500+ transitions indicates sustained physical instability: faulty cable, degraded SFP, switch port fault, or NIC hardware failure."$'\t'"Replace cable or SFP; try a different switch port; run: ethtool -d ${iface}")
    elif [[ "$carrier_changes" -gt 20 ]]; then
      findings+=("WARN"$'\t'"Elevated carrier changes since boot"$'\t'"${carrier_changes} link state changes since boot (cumulative). A healthy link typically has 1–5 total changes. More than 20 suggests intermittent instability."$'\t'"Check cable, SFP module, or switch port")
    fi
  fi

  # EEE enabled
  if echo "$ethtool_eee_out" | grep -qi "EEE status: enabled"; then
    findings+=("CAUSE"$'\t'"Energy-Efficient Ethernet (EEE) enabled"$'\t'"EEE allows the NIC to enter low-power states, causing link drops"$'\t'"ethtool --set-eee ${iface} eee off")
  fi

  # NIC power management (runtime PM)
  if [[ "$power_control" == "auto" ]]; then
    findings+=("CAUSE"$'\t'"NIC power management enabled (runtime PM)"$'\t'"Runtime PM (power/control=auto) can suspend the NIC and drop the link"$'\t'"echo 'on' > /sys/class/net/${iface}/device/power/control")
  fi

  # RX CRC errors
  local rx_crc
  rx_crc=$(echo "$ethtool_s_out" | grep -i "rx_crc_errors" | awk '{print $2}' | head -1 || true)
  if [[ -n "$rx_crc" ]] && [[ "$rx_crc" =~ ^[0-9]+$ ]] && [[ "$rx_crc" -gt 0 ]]; then
    findings+=("CAUSE"$'\t'"RX CRC errors detected"$'\t'"${rx_crc} CRC errors — indicates physical layer fault (cable/SFP/switch port)"$'\t'"Replace cable or SFP; check switch port error counters")
  fi

  # Half-duplex
  if echo "$ethtool_out" | grep -qi "Duplex: Half"; then
    findings+=("WARN"$'\t'"Half-duplex detected"$'\t'"Half-duplex causes collisions and link instability at high load"$'\t'"ethtool -s ${iface} speed 1000 duplex full autoneg off")
  fi

  # Speed/duplex unreadable — autoneg failure or link down
  if [[ "${speed:-}" == "Unknown!" || "${speed:-}" == "Unknown" ]]; then
    findings+=("CAUSE"$'\t'"Link speed unreadable — auto-negotiation failure"$'\t'"The NIC reports unknown speed and duplex, meaning it cannot determine link parameters. This usually means the link is physically down, auto-negotiation has completely failed, or the NIC/driver has faulted. Combined with high carrier changes, this is a strong indicator of physical layer failure."$'\t'"Try forcing speed: ethtool -s ${iface} speed 1000 duplex full autoneg off  or check cable/SFP/switch port autoneg settings")
  fi

  # No physical link
  if echo "$ethtool_out" | grep -qi "Link detected: no"; then
    findings+=("CAUSE"$'\t'"No physical link detected"$'\t'"No carrier signal — check cable, SFP, switch port"$'\t'"Verify cable is seated; check switch port status")
  fi

  # dmesg: hardware error / fatal
  if echo "$dmesg_out" | grep -qi "hardware error\|fatal"; then
    findings+=("CAUSE"$'\t'"Hardware error in kernel log"$'\t'"Kernel reported hardware error for ${iface} — possible NIC failure"$'\t'"Check full dmesg: dmesg | grep -i ${iface}")
  fi

  # dmesg: reset / reinit
  if echo "$dmesg_out" | grep -qi "reset\|reinit"; then
    findings+=("WARN"$'\t'"NIC reset/reinit events in kernel log"$'\t'"Kernel log shows NIC resets for ${iface}"$'\t'"Check full dmesg: dmesg | grep -i ${iface}")
  fi

  # node_exporter: RX errors > 0
  if [[ -n "$ne_rx_err" ]] && [[ "$ne_rx_err" =~ ^[0-9]+$ ]] && [[ "$ne_rx_err" -gt 0 ]]; then
    findings+=("WARN"$'\t'"RX errors (node_exporter)"$'\t'"${ne_rx_err} RX errors seen — possible cable or hardware fault"$'\t'"Check cable; run: ethtool -S ${iface} | grep -i error")
  fi

  # node_exporter: TX errors > 0
  if [[ -n "$ne_tx_err" ]] && [[ "$ne_tx_err" =~ ^[0-9]+$ ]] && [[ "$ne_tx_err" -gt 0 ]]; then
    findings+=("WARN"$'\t'"TX errors (node_exporter)"$'\t'"${ne_tx_err} TX errors seen — possible congestion or hardware fault"$'\t'"Check switch port; run: ethtool -S ${iface} | grep -i error")
  fi

  # TX drops — rate-based when packet totals available (>1% = CAUSE, >0.1% = WARN per
  # Prometheus community standard and TCP performance research showing >0.1% loss degrades
  # throughput). Falls back to absolute counts only when NE packet data is unavailable.
  local _tx_drop_cause=0
  if [[ -n "$ne_tx_drop" ]] && [[ "$ne_tx_drop" =~ ^[0-9]+$ ]] && [[ "$ne_tx_drop" -gt 0 ]]; then
    local _tx_drop_fired=0
    if [[ -n "$ne_tx_packets" && "$ne_tx_packets" =~ ^[0-9]+$ && "$ne_tx_packets" -gt 0 ]]; then
      local _tx_drop_rate_pct _tx_drop_rate_int
      _tx_drop_rate_pct=$(awk -v d="$ne_tx_drop" -v p="$ne_tx_packets" \
        'BEGIN{printf "%.4f", d/p*100}')
      _tx_drop_rate_int=$(awk -v v="$_tx_drop_rate_pct" 'BEGIN{printf "%d", v*1000}')
      if [[ "$_tx_drop_rate_int" -gt 1000 ]]; then   # > 1.000%
        findings+=("CAUSE"$'\t'"Severe TX packet loss"$'\t'"${ne_tx_drop} TX drops out of ${ne_tx_packets} packets (${_tx_drop_rate_pct}% loss rate since boot). Loss >1% significantly degrades TCP throughput and indicates ring buffer exhaustion, driver overload, or physical layer instability."$'\t'"Check: ethtool -g ${iface} for ring buffer size; ethtool -S ${iface} | grep -i drop")
        _tx_drop_cause=1; _tx_drop_fired=1
      elif [[ "$_tx_drop_rate_int" -gt 100 ]]; then  # > 0.100%
        findings+=("WARN"$'\t'"Elevated TX packet loss"$'\t'"${ne_tx_drop} TX drops out of ${ne_tx_packets} packets (${_tx_drop_rate_pct}% loss rate since boot). Loss >0.1% measurably degrades TCP throughput."$'\t'"Run: ethtool -S ${iface} | grep -i drop")
        _tx_drop_fired=1
      fi
    fi
    if [[ "$_tx_drop_fired" -eq 0 ]]; then
      # Fallback: packet totals unavailable; absolute counts are traffic-volume-dependent
      if [[ "$ne_tx_drop" -gt 5000 ]]; then
        findings+=("CAUSE"$'\t'"Severe TX drop count"$'\t'"${ne_tx_drop} TX drops (packet total unavailable — rate cannot be computed). Enable node_exporter for rate-based analysis."$'\t'"Check: ethtool -g ${iface} for ring buffer size; ethtool -S ${iface} | grep -i drop")
        _tx_drop_cause=1
      elif [[ "$ne_tx_drop" -gt 100 ]]; then
        findings+=("WARN"$'\t'"Elevated TX drop count"$'\t'"${ne_tx_drop} TX drops (packet total unavailable — significance depends on traffic volume). Enable node_exporter for rate-based analysis."$'\t'"Run: ethtool -S ${iface} | grep -i drop")
      fi
    fi
  fi

  # RX drops — same rate-based approach as TX drops
  if [[ -n "$ne_rx_drop" ]] && [[ "$ne_rx_drop" =~ ^[0-9]+$ ]] && [[ "$ne_rx_drop" -gt 0 ]]; then
    local _rx_drop_fired=0
    if [[ -n "$ne_rx_packets" && "$ne_rx_packets" =~ ^[0-9]+$ && "$ne_rx_packets" -gt 0 ]]; then
      local _rx_drop_rate_pct _rx_drop_rate_int
      _rx_drop_rate_pct=$(awk -v d="$ne_rx_drop" -v p="$ne_rx_packets" \
        'BEGIN{printf "%.4f", d/p*100}')
      _rx_drop_rate_int=$(awk -v v="$_rx_drop_rate_pct" 'BEGIN{printf "%d", v*1000}')
      if [[ "$_rx_drop_rate_int" -gt 1000 ]]; then   # > 1.000%
        findings+=("CAUSE"$'\t'"Severe RX packet loss"$'\t'"${ne_rx_drop} RX drops out of ${ne_rx_packets} packets (${_rx_drop_rate_pct}% loss rate since boot). The receive buffer is discarding a significant fraction of incoming frames. Causes: NIC ring buffer too small, CPU interrupt starvation (/proc/net/softnet_stat time_squeeze), or physical layer instability."$'\t'"Check: ethtool -g ${iface} for ring buffer size; ethtool -K ${iface} gro on; check CPU load with top")
        _rx_drop_fired=1
      elif [[ "$_rx_drop_rate_int" -gt 100 ]]; then  # > 0.100%
        findings+=("WARN"$'\t'"Elevated RX packet loss"$'\t'"${ne_rx_drop} RX drops out of ${ne_rx_packets} packets (${_rx_drop_rate_pct}% loss rate since boot). Loss >0.1% measurably impacts TCP throughput."$'\t'"Run: ethtool -S ${iface} | grep -i drop; ethtool -g ${iface}")
        _rx_drop_fired=1
      fi
    fi
    if [[ "$_rx_drop_fired" -eq 0 ]]; then
      # Fallback: packet totals unavailable
      if [[ "$ne_rx_drop" -gt 5000 ]]; then
        findings+=("CAUSE"$'\t'"Severe RX drop count"$'\t'"${ne_rx_drop} RX drops (packet total unavailable — rate cannot be computed). Enable node_exporter for rate-based analysis."$'\t'"Check: ethtool -g ${iface}; ethtool -K ${iface} gro on")
      elif [[ "$ne_rx_drop" -gt 100 ]]; then
        findings+=("WARN"$'\t'"Elevated RX drop count"$'\t'"${ne_rx_drop} RX drops (packet total unavailable — significance depends on traffic volume). Enable node_exporter for rate-based analysis."$'\t'"Run: ethtool -S ${iface} | grep -i drop; ethtool -g ${iface}")
      fi
    fi
  fi

  # Combined physical-layer failure signature (>= 2 of 3 indicators present).
  # TX drop component uses the _tx_drop_cause flag set by the rate-based analysis above,
  # so the synthesis threshold matches the proven rate threshold, not an arbitrary count.
  local _phys_indicators=0
  [[ "${speed:-}" == "Unknown!" || "${speed:-}" == "Unknown" ]] && \
    (( _phys_indicators++ )) || true
  [[ -n "$carrier_changes" && "$carrier_changes" =~ ^[0-9]+$ && \
     "$carrier_changes" -gt 500 ]] && (( _phys_indicators++ )) || true
  [[ "${_tx_drop_cause}" -eq 1 ]] && (( _phys_indicators++ )) || true
  if (( _phys_indicators >= 2 )); then
    findings+=("CAUSE"$'\t'"Physical layer failure signature"$'\t'"Multiple indicators point to a physical layer fault: unknown speed negotiation, severe carrier instability (${carrier_changes:-?} transitions), and significant TX packet loss. This combination is characteristic of a damaged cable, failed SFP transceiver, or faulty switch port."$'\t'"1. Replace the patch cable  2. Try a different switch port  3. If SFP: swap the transceiver  4. Run: ethtool -d ${iface} for NIC register dump")
  fi

  # iperf3: TCP retransmits > 0
  if [[ -n "$iperf3_retransmits" ]] && [[ "$iperf3_retransmits" =~ ^[0-9]+$ ]] && \
     [[ "$iperf3_retransmits" -gt 0 ]]; then
    findings+=("WARN"$'\t'"TCP retransmits during iperf3 test"$'\t'"${iperf3_retransmits} retransmits in 5s test to ${IPERF3_SERVER} — congestion or packet loss"$'\t'"Test longer: iperf3 -c ${IPERF3_SERVER} -t 30; check switch port buffers")
  fi

  # Known driver advisories (sourced from official vendor/kernel documentation)
  local _adv_drv_name _adv_drv_ver _adv_drv_fw
  _adv_drv_name=$(echo "$ethtool_i_out" | grep "^driver:"           | awk '{print $2}' | head -1 || true)
  _adv_drv_ver=$(echo  "$ethtool_i_out" | grep "^version:"          | awk '{print $2}' | head -1 || true)
  _adv_drv_fw=$(echo   "$ethtool_i_out" | grep "^firmware-version:" | awk '{print $2}' | head -1 || true)
  if [[ -n "$_adv_drv_name" ]]; then
    while IFS=$'\t' read -r adv_level adv_title adv_desc adv_fix adv_src; do
      [[ -z "$adv_level" ]] && continue
      findings+=("${adv_level}"$'\t'"${adv_title}"$'\t'"${adv_desc}"$'\t'"${adv_fix}  |  See: ${adv_src}")
    done < <(_drv_advisories "$_adv_drv_name" "$_adv_drv_ver" "$_adv_drv_fw" "$iface")
  fi

  # USB NIC — high RX drops with a stable link strongly implicate the USB subsystem
  # rather than the Ethernet cable.  Only add these findings when we know it's USB.
  if [[ "$_iface_is_usb" -eq 1 ]]; then
    if [[ -n "$ne_rx_drop" && "$ne_rx_drop" =~ ^[0-9]+$ && "$ne_rx_drop" -gt 100 ]]; then
      local _cc="${carrier_changes:-0}"
      if [[ "$_cc" =~ ^[0-9]+$ && "$_cc" -lt 20 ]]; then
        findings+=("WARN"$'\t'"USB NIC: high RX drops with stable link"$'\t'"${ne_rx_drop} RX drops on ${_adv_drv_name:-cdc_ncm} with only ${_cc} carrier changes. A stable link and high drop count on a USB Ethernet adapter strongly suggests a USB-side issue — NCM aggregation limits, URB pool exhaustion, or USB host-controller bandwidth contention — rather than an Ethernet cable or switch port fault. Swapping the Ethernet cable and switch port will not resolve drops that originate in the USB subsystem."$'\t'"Check: dmesg | grep -iE 'cdc_ncm|xhci|usb.*reset'; try a different USB root-hub port; replace the USB adapter if drops persist")
      fi
    fi
    if [[ "${speed:-}" == "Unknown!" || "${speed:-}" == "Unknown" ]]; then
      findings+=("INFO"$'\t'"USB NIC: Unknown speed is a driver limitation, not autoneg failure"$'\t'"Many USB CDC Ethernet adapters (${_adv_drv_name:-cdc_ncm}) do not expose link speed via ethtool. An Unknown speed result does not indicate cable or autoneg failure — it is a known limitation of USB NIC drivers. Use ip link show ${iface} to confirm the interface is UP/LOWER_UP."$'\t'"ip link show ${iface}")
    fi
  fi

  # 5. Historical system load at flap time (Prometheus, if configured)
  if [[ -n "$PROM_URL" || -n "${_LINK_FLAP_TEST_PROM:-}" ]]; then
    local _wiz_first_epoch=""
    if [[ -f "$TMPFILE" ]]; then
      _wiz_first_epoch=$(awk -v ifc="$iface" '$2==ifc {print $1; exit}' "$TMPFILE" 2>/dev/null || true)
    fi
    if [[ -n "$_wiz_first_epoch" ]]; then
      local _wiz_cpu _wiz_mem
      _wiz_cpu=$(prom_query_at \
        'avg(rate(node_cpu_seconds_total{mode="idle"}[5m]))*100' "$_wiz_first_epoch")
      _wiz_mem=$(prom_query_at \
        'node_memory_MemAvailable_bytes/node_memory_MemTotal_bytes*100' "$_wiz_first_epoch")
      if [[ -n "$_wiz_cpu" ]]; then
        local _wiz_cpu_int
        _wiz_cpu_int=$(printf "%.0f" "$_wiz_cpu")
        if (( _wiz_cpu_int < 15 )); then
          findings+=("CAUSE"$'\t'"CPU saturation at flap time"$'\t'"CPU idle was ${_wiz_cpu_int}% when flapping began — system was heavily loaded. Under this level of saturation the kernel's NAPI softirq budget can be exhausted before the NIC ring buffer drains, causing packet loss and link instability. Direct evidence of softirq starvation is visible in /proc/net/softnet_stat (column 9: time_squeeze)."$'\t'"Investigate with: top -b -n1 | head -20; also check: awk '{print \$10}' /proc/net/softnet_stat")
        elif (( _wiz_cpu_int < 30 )); then
          findings+=("WARN"$'\t'"High CPU load at flap time"$'\t'"CPU idle was ${_wiz_cpu_int}% when flapping began — elevated load can delay NIC interrupt processing and increase softirq latency. Check /proc/net/softnet_stat (column 9: time_squeeze) for direct evidence."$'\t'"Check: top, htop; also: awk '{print \$10}' /proc/net/softnet_stat")
        fi
      fi
      if [[ -n "$_wiz_mem" ]]; then
        local _wiz_mem_int
        _wiz_mem_int=$(printf "%.0f" "$_wiz_mem")
        if (( _wiz_mem_int < 10 )); then
          findings+=("WARN"$'\t'"Low memory at flap time"$'\t'"Only ${_wiz_mem_int}% memory was available when flapping began — memory pressure can cause driver buffer exhaustion"$'\t'"Check: free -h; consider adding swap or reducing memory consumers")
        fi
      fi
    fi
  fi

  # 6. Pattern analysis — use TMPFILE events for the interface
  local -a iface_events=()
  if [[ -f "$TMPFILE" ]]; then
    mapfile -t iface_events < <(grep -F -- " ${iface} " "$TMPFILE" | sort -n 2>/dev/null || true)
  fi
  local event_count=${#iface_events[@]}
  findings+=("INFO"$'\t'"Flap events in scan window"$'\t'"${event_count} link event(s) found in the last ${WINDOW_MINUTES}m window"$'\t'"Use -v to see individual events")

  if [[ $event_count -ge 4 ]]; then
    local -a epochs=()
    local evt
    for evt in "${iface_events[@]}"; do
      epochs+=("$(echo "$evt" | awk '{print $1}')")
    done
    local i max_interval=0 min_interval=999999 spread=0
    for (( i=1; i<${#epochs[@]}; i++ )); do
      local interval=$(( epochs[i] - epochs[i-1] ))
      [[ $interval -gt $max_interval ]] && max_interval=$interval
      [[ $interval -lt $min_interval ]] && min_interval=$interval
    done
    spread=$(( max_interval - min_interval ))
    # Spread < 30 s across all inter-event gaps means events are evenly spaced.
    # Even spacing suggests a timer-driven cause: STP hello/TCN, LACP PDU, or power-management cycle.
    if [[ $spread -lt 30 ]]; then
      findings+=("WARN"$'\t'"Regular flap interval detected"$'\t'"Inter-event intervals are consistent (spread ${spread}s) — may indicate STP, LACP, or power-cycle timer"$'\t'"Check STP: bridge link; check LACP: teamdctl; check power management")
    fi
  fi

  # 6. Print report (terminal + capture for file)
  local -a report_lines=()
  local ts_now; ts_now=$(date "+%Y-%m-%d %H:%M:%S")
  local SEP="════════════════════════════════════════════════════════════"

  _rpt() {
    local _l="$1"
    echo -e "$_l"
    report_lines+=("$(echo -e "$_l" | sed 's/\x1b\[[0-9;]*m//g')")
  }

  _rpt ""
  if [[ -n "${_LINK_FLAP_TEST_WIZARD_DIR:-}" ]]; then
    _rpt "${YELLOW}${BOLD}  !! SYNTHETIC TEST DATA — wizard sysfs/commands are mocked, not real hardware !!${RESET}"
    _rpt ""
  fi
  _rpt "${BOLD}${SEP}${RESET}"
  _rpt "${BOLD}  Diagnostic Report — ${iface}${RESET}"
  _rpt "  Generated : ${ts_now}"
  _rpt "  Backup ID : ${backup_id}"
  _rpt "${BOLD}${SEP}${RESET}"
  _rpt ""
  _rpt "${BOLD}Interface State${RESET}"
  _rpt "  operstate      : ${operstate:-unknown}"

  # carrier_changes with severity hint
  local _cc_hint=""
  if [[ -n "$carrier_changes" && "$carrier_changes" =~ ^[0-9]+$ ]]; then
    if   (( carrier_changes > 500 )); then _cc_hint="  [SEVERE — each change = 1 link drop+restore]"
    elif (( carrier_changes > 20  )); then _cc_hint="  [elevated — stable links expect < 5]"
    else                                   _cc_hint="  [normal]"
    fi
  fi
  _rpt "  carrier_changes: ${carrier_changes:-unknown}${_cc_hint}"

  # speed with hint when unreadable
  local _speed_hint=""
  [[ "${speed:-}" == "Unknown!" || "${speed:-}" == "Unknown" ]] && \
    _speed_hint="  [unreadable — autoneg failed or link down]" || true
  _rpt "  speed          : ${speed:-unknown}${_speed_hint}"

  # duplex with hint
  local _duplex_hint=""
  [[ "${duplex:-}" == "Half" ]] && _duplex_hint="  [collision risk at high load]" || true
  [[ "${duplex:-}" == "Unknown" || "${duplex:-}" == "Unknown!" ]] && \
    _duplex_hint="  [unreadable — same cause as unknown speed]" || true
  _rpt "  duplex         : ${duplex:-unknown}${_duplex_hint}"

  _rpt "  autoneg        : ${autoneg:-unknown}"
  _rpt "  power/control  : ${power_control:-unknown}"
  if [[ -n "$_NE_METRICS_CACHE" ]]; then
    local ne_state_str=""
    if [[ "$ne_up" == "1" ]]; then
      ne_state_str="UP"
    elif [[ "$ne_up" == "0" ]]; then
      ne_state_str="DOWN"
    fi
    _rpt ""
    _rpt "${BOLD}node_exporter Metrics${RESET}"
    if [[ -n "$ne_state_str" ]]; then _rpt "  link state     : ${ne_state_str}"; fi
    if [[ -n "$ne_rx_err"    ]]; then _rpt "  RX errors      : ${ne_rx_err} total"; fi
    if [[ -n "$ne_tx_err"    ]]; then _rpt "  TX errors      : ${ne_tx_err} total"; fi
    if [[ -n "$ne_rx_drop"   ]]; then _rpt "  RX drops       : ${ne_rx_drop} total"; fi
    if [[ -n "$ne_tx_drop"   ]]; then _rpt "  TX drops       : ${ne_tx_drop} total"; fi
  fi
  if [[ -n "$_IPERF3_RESULT_CACHE" ]]; then
    local mbps_str="?"
    if [[ -n "$iperf3_bps" ]]; then
      mbps_str=$(python3 -c "import sys; print(f'{float(sys.argv[1])/1e6:.1f}')" "$iperf3_bps" 2>/dev/null || echo "?")
    fi
    _rpt ""
    if [[ -n "$_IPERF3_BIND_IP" ]]; then
      _rpt "${BOLD}iperf3 Results${RESET}  (→ ${IPERF3_SERVER} via ${_IPERF3_BIND_IP})"
    else
      _rpt "${BOLD}iperf3 Results${RESET}  (→ ${IPERF3_SERVER}, unbound)"
    fi
    _rpt "  bandwidth      : ${mbps_str} Mbps"
    if [[ -n "$iperf3_retransmits" ]]; then _rpt "  retransmits    : ${iperf3_retransmits}"; fi
  fi
  _rpt ""
  _rpt "${BOLD}Findings${RESET}"

  local cause_count=0 warn_count=0
  local finding idx

  # Pass 1 — at-a-glance summary table
  _rpt ""
  _rpt "  ${DIM}#  Level   Title${RESET}"
  _rpt "  ${DIM}─  ──────  ───────────────────────────────────────────────────────${RESET}"
  idx=0
  for finding in "${findings[@]}"; do
    local f_level f_title f_desc f_fix
    IFS=$'\t' read -r f_level f_title f_desc f_fix <<< "$finding"
    (( idx++ )) || true
    case "$f_level" in
      CAUSE) _rpt "  ${idx}  ${RED}CAUSE${RESET}   ${f_title}" ;;
      WARN)  _rpt "  ${idx}  ${YELLOW}WARN${RESET}    ${f_title}" ;;
      INFO)  _rpt "  ${idx}  ${CYAN}INFO${RESET}    ${f_title}" ;;
    esac
  done

  # Pass 2 — detailed blocks
  _rpt ""
  _rpt "  ${DIM}── Details ────────────────────────────────────────────────────${RESET}"
  idx=0
  for finding in "${findings[@]}"; do
    local f_level f_title f_desc f_fix
    IFS=$'\t' read -r f_level f_title f_desc f_fix <<< "$finding"
    (( idx++ )) || true
    _rpt ""
    case "$f_level" in
      CAUSE)
        _rpt "  [${idx}] ${RED}[CAUSE]${RESET} ${BOLD}${f_title}${RESET}"
        _rpt "      ${f_desc}"
        _rpt "      ${GREEN}[FIX]${RESET}  ${f_fix}"
        (( cause_count++ )) || true
        ;;
      WARN)
        _rpt "  [${idx}] ${YELLOW}[WARN]${RESET}  ${BOLD}${f_title}${RESET}"
        _rpt "      ${f_desc}"
        _rpt "      ${GREEN}[FIX]${RESET}  ${f_fix}"
        (( warn_count++ )) || true
        ;;
      INFO)
        _rpt "  [${idx}] ${CYAN}[INFO]${RESET}  ${f_title}: ${f_desc}"
        ;;
    esac
  done

  _rpt ""
  _rpt "${BOLD}Summary${RESET}"
  _rpt "  Causes  : ${cause_count}"
  _rpt "  Warnings: ${warn_count}"
  _rpt "  Report  : ${REPORT_DIR}/${backup_id}.txt"
  _rpt "  Rollback: ./flap -r ${backup_id}"
  _rpt "  Verify  : ./flap -i ${iface} -w 10  (after applying fix)"
  _rpt ""

  # 7. Fault localization section
  run_fault_localization "$iface" \
    "$ethtool_i_out" "$ethtool_out" "$ip_route_out" "$all_links_out" \
    "$resolv_conf_out" "$dmesg_out" \
    "${carrier_changes:-}" "${speed:-}" "${rx_crc:-}" "${ne_tx_drop:-}" \
    "${dut_carrier_changes:-}" "${dut_operstate:-}" "${dut_speed:-}" \
    "${_tx_drop_cause:-0}" \
    "${rx_power_dbm:-}" "${tx_power_dbm:-}" \
    "${lldp_peer_name:-}" "${lldp_peer_port:-}" "${_lldp_available:-0}"

  # 8. Save report (strip ANSI already done in _rpt)
  printf '%s\n' "${report_lines[@]}" > "${REPORT_DIR}/${backup_id}.txt"
}

# ── Fault Localization ────────────────────────────────────────────────────────
# Layer-by-layer fault isolation appended to the wizard report.
# Args: iface ethtool_i_out ethtool_out ip_route_out all_links_out
#       resolv_conf_out dmesg_out
#       carrier_changes speed rx_crc ne_tx_drop
#       dut_carrier_changes dut_operstate dut_speed
#       tx_drop_cause (1 if TX drops reached CAUSE level, 0 otherwise)
#       rx_power_dbm tx_power_dbm (SFP DOM optical power in dBm, empty if unavailable)
#       lldp_peer_name lldp_peer_port (empty if unknown)
#       lldp_available (1 if lldpctl present, 0 otherwise)
run_fault_localization() {
  local iface="$1"
  local ethtool_i_out="$2"
  local ethtool_out="$3"
  local ip_route_out="$4"
  local all_links_out="$5"
  local resolv_conf_out="$6"
  local dmesg_out="$7"
  local carrier_changes="$8"
  local speed="$9"
  local rx_crc="${10}"
  local ne_tx_drop="${11}"
  local dut_carrier_changes="${12}"
  local dut_operstate="${13}"
  local dut_speed="${14}"
  local tx_drop_cause="${15:-0}"
  local rx_power_dbm="${16:-}"
  local tx_power_dbm="${17:-}"
  local lldp_peer_name="${18:-}"
  local lldp_peer_port="${19:-}"
  local lldp_available="${20:-0}"

  local SEP="════════════════════════════════════════════════════════════"

  _rpt ""
  _rpt "${BOLD}${SEP}${RESET}"
  _rpt "${BOLD}  Fault Localization — ${iface}${RESET}"
  _rpt "${BOLD}${SEP}${RESET}"
  _rpt ""

  # ── Layer 1: Physical (cable / connector / SFP) ───────────────────────────
  local l1_status="OK"
  local -a l1_evidence=()
  if [[ "${speed:-}" == "Unknown!" || "${speed:-}" == "Unknown" ]]; then
    if [[ "$_iface_is_usb" -eq 1 ]]; then
      # USB NICs commonly report Unknown speed — this is a driver limitation, not autoneg failure.
      l1_evidence+=("Unknown speed (expected ${_adv_drv_name:-USB NIC} driver limitation — not an autoneg fault)")
    else
      l1_status="SUSPECT"; l1_evidence+=("Unknown speed (autoneg failed)")
    fi
  fi
  if [[ -n "$carrier_changes" && "$carrier_changes" =~ ^[0-9]+$ && \
        "$carrier_changes" -gt 500 ]]; then
    l1_status="SUSPECT"; l1_evidence+=("${carrier_changes} carrier changes (severe)")
  fi
  if [[ -n "$rx_crc" && "$rx_crc" =~ ^[0-9]+$ && "$rx_crc" -gt 0 ]]; then
    l1_status="SUSPECT"; l1_evidence+=("RX CRC errors (${rx_crc})")
  fi
  echo "$ethtool_out" | grep -qi "Link detected: no" && \
    l1_status="SUSPECT" && l1_evidence+=("No physical link detected")
  # tx_drop_cause is set by run_wizard's rate-based analysis (>1% loss rate or >5000 absolute fallback)
  if [[ "${tx_drop_cause}" -eq 1 ]]; then
    l1_status="SUSPECT"; l1_evidence+=("Severe TX packet loss (${ne_tx_drop} drops)")
  fi

  # 6. SFP DOM — RX optical power (signal arriving from the remote end)
  #    Low RX power implicates the remote SFP, fibre attenuation, or dirty connectors.
  #    Typical thresholds: warn < -30 dBm, critical < -35 dBm
  if [[ -n "$rx_power_dbm" ]]; then
    if awk "BEGIN{exit !($rx_power_dbm < -35)}"; then
      l1_status="SUSPECT"
      l1_evidence+=("RX optical power ${rx_power_dbm} dBm — remote SFP or fibre degraded")
    elif awk "BEGIN{exit !($rx_power_dbm < -30)}"; then
      l1_evidence+=("RX optical power ${rx_power_dbm} dBm (marginal; monitor)")
    fi
  fi

  # 7. SFP DOM — TX optical power (local laser health; most SFPs rated -9 dBm minimum)
  if [[ -n "$tx_power_dbm" ]]; then
    if awk "BEGIN{exit !($tx_power_dbm < -9)}"; then
      l1_status="SUSPECT"
      l1_evidence+=("TX optical power ${tx_power_dbm} dBm — local SFP laser degraded")
    fi
  fi

  # 8. LLDP neighbour — remote device visibility
  local lldp_note=""
  if [[ -n "$lldp_peer_name" ]]; then
    lldp_note="${lldp_peer_name}${lldp_peer_port:+ port $lldp_peer_port}"
  elif [[ "$lldp_available" -eq 1 ]]; then
    # lldpctl present but no neighbour on an up link is suspicious
    echo "$ethtool_out" | grep -qi "Link detected: yes" && \
      l1_evidence+=("No LLDP neighbour on an up link — remote port may be down or misconfigured")
  fi

  local l1_col="$GREEN"
  [[ "$l1_status" == "SUSPECT" ]] && l1_col="$RED"
  _rpt "  Layer 1 — Physical (cable / connector / SFP)"
  _rpt "    Status   : ${l1_col}${l1_status}${RESET}"
  [[ -n "$lldp_note" ]] && _rpt "    Remote   : ${lldp_note}"
  if [[ "${#l1_evidence[@]}" -gt 0 ]]; then
    _rpt "    Evidence : $(IFS='; '; echo "${l1_evidence[*]}")"
    if echo "${l1_evidence[*]}" | grep -qi "remote\|LLDP"; then
      _rpt "    Next step: Investigate remote device/port${lldp_note:+ ($lldp_note)}; check far-end SFP and fibre connectors"
    elif [[ "$_iface_is_usb" -eq 1 ]]; then
      _rpt "    Next step: Cable+port already swapped → the USB adapter, USB cable, or USB host controller is suspect"
    else
      _rpt "    Next step: Replace cable; try a different switch port; swap SFP"
    fi
  fi
  if [[ "$_iface_is_usb" -eq 1 ]]; then
    _rpt "    USB path : ${_iface_usb_path:-unknown}"
    if [[ -n "$ncm_params_out" ]]; then
      _rpt "    NCM params:"
      while IFS= read -r _p; do
        _rpt "               ${_p}"
      done <<< "$ncm_params_out"
    fi
    if [[ -n "$usb_dmesg_out" ]]; then
      _rpt "    USB events (recent dmesg):"
      while IFS= read -r _u; do
        _rpt "               ${_u}"
      done <<< "$usb_dmesg_out"
    fi
  fi
  _rpt ""

  # ── Layer 2: NIC Driver ───────────────────────────────────────────────────
  local drv_name drv_ver drv_fw
  drv_name=$(echo "$ethtool_i_out" | grep "^driver:"   | awk '{print $2}' | head -1 || true)
  drv_ver=$(echo  "$ethtool_i_out" | grep "^version:"  | awk '{print $2}' | head -1 || true)
  drv_fw=$(echo   "$ethtool_i_out" | grep "^firmware-version:" | awk '{print $2}' | head -1 || true)

  local l2drv_status="OK"
  [[ -z "$drv_name" ]] && l2drv_status="UNKNOWN"
  echo "$dmesg_out" | grep -qi "reset\|reinit" && l2drv_status="SUSPECT"
  echo "$dmesg_out" | grep -qi "firmware.*fail\|failed to load firmware" && l2drv_status="SUSPECT"
  # Severe TX drops with stable carrier_changes → driver queue issue, not physical
  # Uses tx_drop_cause flag (rate-based CAUSE level) to avoid arbitrary absolute threshold
  if [[ "${tx_drop_cause}" -eq 1 && \
        -n "$carrier_changes" && "$carrier_changes" =~ ^[0-9]+$ && "$carrier_changes" -lt 5 ]]; then
    l2drv_status="SUSPECT"
  fi

  local l2drv_col="$GREEN"
  [[ "$l2drv_status" == "SUSPECT" ]] && l2drv_col="$RED"
  [[ "$l2drv_status" == "UNKNOWN" ]] && l2drv_col="$DIM"
  _rpt "  Layer 2 — NIC Driver"
  _rpt "    Status   : ${l2drv_col}${l2drv_status}${RESET}"
  if [[ -n "$drv_name" ]]; then
    local drv_line="    Driver   : ${drv_name}"
    [[ -n "$drv_ver" ]] && drv_line+="  v${drv_ver}"
    [[ -n "$drv_fw"  ]] && drv_line+="  fw ${drv_fw}"
    _rpt "$drv_line"
    while IFS=$'\t' read -r adv_level adv_title adv_desc adv_fix adv_src; do
      [[ -z "$adv_level" ]] && continue
      local adv_col="$YELLOW"
      [[ "$adv_level" == "INFO" ]] && adv_col="$CYAN"
      _rpt "    Advisory : ${adv_col}${adv_title}${RESET}"
      _rpt "               ${adv_desc}"
      [[ -n "$adv_src" ]] && _rpt "               ${DIM}See: ${adv_src}${RESET}"
    done < <(_drv_advisories "$drv_name" "$drv_ver" "$drv_fw" "$iface")
  else
    _rpt "    Driver   : (ethtool -i not available)"
  fi
  _rpt ""

  # ── Layer 2: Switch Port ──────────────────────────────────────────────────
  local l2sw_status="UNKNOWN"
  local -a l2sw_evidence=()
  echo "$ethtool_out" | grep -qi "Duplex: Half" && \
    l2sw_status="SUSPECT" && l2sw_evidence+=("Half-duplex — autoneg mismatch with switch")
  # STP changes detected would also be a switch indicator, but that's PCAP-only

  local l2sw_col="$DIM"
  [[ "$l2sw_status" == "SUSPECT" ]] && l2sw_col="$RED"
  _rpt "  Layer 2 — Switch Port"
  _rpt "    Status   : ${l2sw_col}${l2sw_status}${RESET}"
  if [[ "${#l2sw_evidence[@]}" -gt 0 ]]; then
    _rpt "    Evidence : $(IFS='; '; echo "${l2sw_evidence[*]}")"
  else
    _rpt "    Note     : LLDP not available; no STP topology changes seen"
  fi
  _rpt "    Next step: Check switch port error counters; try a different port"
  _rpt ""

  # ── Layer 3: Gateway / Router ─────────────────────────────────────────────
  local gateway
  gateway=$(echo "$ip_route_out" | awk '/^default via/{print $3; exit}' || true)

  local l3_status="UNKNOWN"
  local l3_gw_line="" l3_inet_line=""
  if [[ -n "$gateway" ]]; then
    local ping_gw_out
    ping_gw_out=$(_wiz_cmd ping_gw ping -c 1 -W 2 "$gateway")
    if echo "$ping_gw_out" | grep -q "1 received\|1 packets received"; then
      l3_status="OK"
      local rtt
      rtt=$(echo "$ping_gw_out" | grep -oP 'time=\K[0-9.]+' | head -1 || true)
      l3_gw_line="    Gateway  : ${gateway}  (reachable${rtt:+, ${rtt}ms})"
    else
      l3_status="SUSPECT"
      l3_gw_line="    Gateway  : ${gateway}  (UNREACHABLE — check router/cable to gateway)"
    fi
    # Internet reachability (only if gateway OK)
    if [[ "$l3_status" == "OK" ]]; then
      local ping_inet_out
      ping_inet_out=$(_wiz_cmd ping_inet ping -c 1 -W 2 8.8.8.8)
      if echo "$ping_inet_out" | grep -q "1 received\|1 packets received"; then
        l3_inet_line="    Internet : reachable (8.8.8.8)"
      else
        l3_inet_line="    Internet : UNREACHABLE (gateway OK but no internet — check router/ISP)"
      fi
    fi
  else
    l3_gw_line="    Gateway  : not configured (no default route)"
  fi

  local l3_col="$GREEN"
  [[ "$l3_status" == "SUSPECT" ]] && l3_col="$RED"
  [[ "$l3_status" == "UNKNOWN" ]] && l3_col="$DIM"
  _rpt "  Layer 3 — Gateway / Router"
  _rpt "    Status   : ${l3_col}${l3_status}${RESET}"
  [[ -n "$l3_gw_line"   ]] && _rpt "$l3_gw_line"
  [[ -n "$l3_inet_line" ]] && _rpt "$l3_inet_line"
  _rpt ""

  # ── VPN ──────────────────────────────────────────────────────────────────
  local vpn_iface
  vpn_iface=$(echo "$all_links_out" | grep -oP '(?<=\d: )(tun|tap|wg|vpn|tailscale)\w*' | head -1 || true)
  _rpt "  VPN"
  if [[ -n "$vpn_iface" ]]; then
    local vpn_route
    vpn_route=$(echo "$ip_route_out" | grep "$vpn_iface" | head -1 || true)
    _rpt "    Status   : ${YELLOW}Detected${RESET} (${vpn_iface})"
    [[ -n "$vpn_route" ]] && _rpt "    Route    : ${vpn_route}"
    _rpt "    Note     : Check VPN tunnel stability if routing issues are suspected"
  else
    _rpt "    Status   : ${DIM}Not detected${RESET}"
  fi
  _rpt ""

  # ── DNS ───────────────────────────────────────────────────────────────────
  local nameserver
  nameserver=$(echo "$resolv_conf_out" | awk '/^nameserver/{print $2; exit}' || true)
  local dns_status="UNKNOWN"
  if [[ -n "$nameserver" ]]; then
    local dig_out
    dig_out=$(_wiz_cmd dig_dns dig +short +time=2 +tries=1 google.com "@${nameserver}")
    if [[ -n "$dig_out" ]]; then
      dns_status="OK"
    else
      dns_status="SUSPECT"
    fi
  fi

  local dns_col="$GREEN"
  [[ "$dns_status" == "SUSPECT" ]] && dns_col="$RED"
  [[ "$dns_status" == "UNKNOWN" ]] && dns_col="$DIM"
  _rpt "  DNS"
  _rpt "    Status   : ${dns_col}${dns_status}${RESET}"
  if [[ -n "$nameserver" ]]; then
    _rpt "    Resolver : ${nameserver}${dns_status:+  (google.com ${dns_status,,})}"
  else
    _rpt "    Resolver : not configured (/etc/resolv.conf has no nameserver)"
  fi
  _rpt ""

  # ── DUT Interface ─────────────────────────────────────────────────────────
  local dut_verdict=""
  if [[ -n "$DUT_IFACE" ]]; then
    local dut_status="OK"
    local -a dut_evidence=()

    if [[ -n "$dut_carrier_changes" && "$dut_carrier_changes" =~ ^[0-9]+$ && \
          -n "$carrier_changes" && "$carrier_changes" =~ ^[0-9]+$ ]]; then
      if (( dut_carrier_changes > carrier_changes * 5 && dut_carrier_changes > 20 )); then
        dut_status="SUSPECT"
        dut_evidence+=("DUT carrier changes (${dut_carrier_changes}) >> host (${carrier_changes})")
      fi
    fi
    if [[ "${dut_speed:-}" == "Unknown!" || "${dut_speed:-}" == "Unknown" ]] && \
       [[ "${speed:-}" != "Unknown!" && "${speed:-}" != "Unknown" && -n "${speed:-}" ]]; then
      dut_status="SUSPECT"
      dut_evidence+=("DUT speed Unknown! while host speed is ${speed}")
    fi
    [[ "${dut_operstate:-}" == "down" || "${dut_operstate:-}" == "unknown" ]] && \
      dut_status="SUSPECT" && dut_evidence+=("DUT operstate=${dut_operstate:-}")

    local dut_col="$GREEN"
    [[ "$dut_status" == "SUSPECT" ]] && dut_col="$RED"
    _rpt "  DUT Interface (${DUT_IFACE} — device under test)"
    _rpt "    Status   : ${dut_col}${dut_status}${RESET}"
    local _cc_display="${dut_carrier_changes:-?}  vs host ${iface}: ${carrier_changes:-?}"
    _rpt "    Carrier changes: ${_cc_display}"
    _rpt "    Speed    : ${dut_speed:-unknown}  vs host ${iface}: ${speed:-unknown}"
    _rpt "    Link state: ${dut_operstate:-unknown}  vs host ${iface}: ${operstate:-unknown}"
    if [[ "${#dut_evidence[@]}" -gt 0 ]]; then
      _rpt "    Evidence : $(IFS='; '; echo "${dut_evidence[*]}")"
    fi
    _rpt ""
    [[ "$dut_status" == "SUSPECT" ]] && \
      dut_verdict="Fault is likely in the DUT or the DUT-host cable. Host interface (${iface}) is stable — the issue is not upstream of this computer."
  fi

  # ── Verdict ───────────────────────────────────────────────────────────────
  local vsep="  ──────────────────────────────────────────────────────────"
  local verdict=""
  if [[ -n "$dut_verdict" ]]; then
    verdict="$dut_verdict"
  elif [[ "$l1_status" == "SUSPECT" && "$l2drv_status" != "SUSPECT" && \
          "$l3_status" != "SUSPECT" ]]; then
    verdict="Fault is most likely in the PHYSICAL LAYER (cable, SFP, or switch port)."
  elif [[ "$l1_status" == "SUSPECT" && "$l2drv_status" == "SUSPECT" ]]; then
    verdict="Physical layer and driver both show issues — address physical first (replace cable/SFP), then check driver/firmware."
  elif [[ "$l1_status" != "SUSPECT" && "$l2drv_status" == "SUSPECT" ]]; then
    verdict="NIC DRIVER or firmware issue — physical layer appears OK. Update driver or firmware; check dmesg for reset events."
  elif [[ "$l3_status" == "SUSPECT" ]]; then
    verdict="GATEWAY/ROUTER unreachable — not a link-layer fault. Check the cable to the gateway and the gateway itself."
  elif [[ "$dns_status" == "SUSPECT" ]]; then
    verdict="DNS resolver issue — link is stable. Check /etc/resolv.conf and firewall rules for UDP port 53."
  elif [[ "$l1_status" == "OK" && "$l2drv_status" == "OK" && \
          "$l3_status" != "SUSPECT" && "$dns_status" != "SUSPECT" ]]; then
    verdict="No fault detected at any monitored layer. The flap may have been transient; monitor with: ./flap -i ${iface} -f 30"
  else
    verdict="Multiple or ambiguous indicators — investigate the PHYSICAL LAYER first (replace cable, try different switch port)."
  fi

  _rpt "$vsep"
  _rpt "  ${BOLD}VERDICT: ${verdict}${RESET}"
  _rpt "$vsep"
}

# ── Step 1: Collect raw log lines ─────────────────────────────────────────────
# Format we aim to emit into TMPFILE for each event:
#   <epoch_seconds> <iface> <UP|DOWN>
#
# We try journald first (Ubuntu 24.04 default). Fall back to flat log files.

SINCE_ARG="${WINDOW_MINUTES} minutes ago"

collect_from_journald() {
  # journalctl --output=short-iso gives lines like:
  #   2024-11-01T14:23:05+0000 hostname kernel: eth0: NIC Link is Down
  local -a jctl_args=(--no-pager --output=short-iso)
  if [[ -n "$SINCE_EPOCH" ]]; then
    jctl_args+=("--since=$(date -d "@$SINCE_EPOCH" "+%Y-%m-%d %H:%M:%S")")
  else
    jctl_args+=("--since=$SINCE_ARG")
  fi
  [[ -n "$UNTIL_EPOCH" ]] && \
    jctl_args+=("--until=$(date -d "@$UNTIL_EPOCH" "+%Y-%m-%d %H:%M:%S")")
  journalctl "${jctl_args[@]}" 2>/dev/null
}

collect_from_syslog() {
  local logfile="$1"
  # syslog/kern.log lines: "Nov  1 14:23:05 hostname kernel: eth0: NIC Link is Down"
  # We only have current-year timestamps — good enough for flap detection
  if [[ -r "$logfile" ]]; then
    if [[ -n "$SINCE_EPOCH" ]]; then
      # Date range specified — read the whole file; the epoch filter handles trimming
      cat "$logfile"
    else
      # Filter roughly by recency using the last N lines proportional to window
      local lines=$(( WINDOW_MINUTES * 200 ))   # ~200 log lines per minute — generous
      tail -n "$lines" "$logfile"
    fi
  fi
}

collect_from_tshark() {
  local pcap="$1"
  if ! command -v tshark &>/dev/null; then
    echo "Error: tshark is not installed (required for -p)." >&2; exit 1
  fi

  # ── STP Topology Change Notifications ─────────────────────────────────────
  # Each TCN BPDU signals a spanning-tree port state change. Consecutive TCNs
  # from the same sender alternate DOWN/UP (first event = something went down,
  # second = recovery, etc.). We name the synthetic iface "stp-<last2octets>".
  tshark -r "$pcap" -q -Y "stp.flags.tc == 1" \
    -T fields -e frame.time_epoch -e eth.src \
    2>/dev/null \
  | awk -v iface_filter="$IFACE_FILTER" '
    NF < 2 { next }
    {
      epoch = int($1)
      mac   = $2
      n     = split(mac, m, ":")
      iface = "stp-" m[n-1] m[n]
      if (iface_filter != "" && iface != iface_filter) next
      state = (last_state[iface] == "DOWN") ? "UP" : "DOWN"
      last_state[iface] = state
      print epoch " " iface " " state
    }'

  # ── LACP synchronisation state changes ────────────────────────────────────
  # Bit 3 of actor_state is the Synchronisation flag (value 8). When it falls
  # to 0 the bond member is no longer in sync → DOWN; when it rises → UP.
  # Emit a record only when the state transitions, to avoid duplicates.
  tshark -r "$pcap" -q -Y "lacp" \
    -T fields -e frame.time_epoch -e eth.src -e lacp.actor_state \
    2>/dev/null \
  | awk -v iface_filter="$IFACE_FILTER" '
    NF < 3 { next }
    {
      epoch = int($1)
      mac   = $2
      n     = split(mac, m, ":")
      iface = "lacp-" m[n-1] m[n]
      if (iface_filter != "" && iface != iface_filter) next
      actor_state = int($3)
      state = (int(actor_state / 8) % 2 == 1) ? "UP" : "DOWN"
      if (state != last_state[iface]) {
        print epoch " " iface " " state
        last_state[iface] = state
      }
    }'
}

# _send_webhook — POST a JSON alert to a Slack, Discord, or generic webhook.
# Args: url event(flapping|cleared) iface [transitions]
_send_webhook() {
  local url="$1" event="$2" iface="$3" transitions="${4:-}"
  local message payload

  if [[ "$event" == "flapping" ]]; then
    message="[FLAPPING] ${iface} — ${transitions} transitions detected"
  else
    message="[CLEARED] ${iface} — link has stabilised"
  fi

  # Test hook: write to log file instead of calling curl
  if [[ -n "${_LINK_FLAP_TEST_WEBHOOK_LOG:-}" ]]; then
    echo "${event}:${iface}:${transitions:-}" >> "$_LINK_FLAP_TEST_WEBHOOK_LOG"
    return 0
  fi

  if [[ "$url" == *"discord.com"* ]]; then
    payload="{\"content\":\"${message}\",\"username\":\"link-flap-detect\"}"
  else
    payload="{\"text\":\"${message}\"}"
  fi

  curl -sf -X POST -H "Content-Type: application/json" \
    -d "$payload" --max-time 5 "$url" >/dev/null 2>&1 || true
}

prom_query() {
  # Query Prometheus instant API; return first result value or empty string.
  # _LINK_FLAP_TEST_PROM: path to a canned JSON response file (test hook).
  local query="$1"
  local response
  if [[ -n "${_LINK_FLAP_TEST_PROM:-}" ]]; then
    response=$(cat "$_LINK_FLAP_TEST_PROM")
  else
    response=$(curl -sf -G "${PROM_URL}/api/v1/query" \
      --data-urlencode "query=$query" \
      --max-time 5 2>/dev/null) || return 0
  fi
  if command -v jq &>/dev/null; then
    echo "$response" | jq -r '.data.result[0].value[1] // empty' 2>/dev/null
  else
    python3 -c "
import json,sys
d=json.loads(sys.stdin.read())
r=d.get('data',{}).get('result',[])
if r: print(r[0]['value'][1])
" <<< "$response" 2>/dev/null
  fi
}

prom_query_at() {
  # Query Prometheus instant API at a specific Unix epoch timestamp.
  # Returns the first result value, or empty string if no data.
  # Uses _LINK_FLAP_TEST_PROM for offline testing (same hook as prom_query).
  local query="$1" epoch="$2"
  local response
  if [[ -n "${_LINK_FLAP_TEST_PROM:-}" ]]; then
    response=$(cat "$_LINK_FLAP_TEST_PROM")
  else
    response=$(curl -sf -G "${PROM_URL}/api/v1/query" \
      --data-urlencode "query=$query" \
      --data-urlencode "time=$epoch" \
      --max-time 5 2>/dev/null) || return 0
  fi
  if command -v jq &>/dev/null; then
    echo "$response" | jq -r '.data.result[0].value[1] // empty' 2>/dev/null
  else
    python3 -c "
import json,sys
d=json.loads(sys.stdin.read())
r=d.get('data',{}).get('result',[])
if r: print(r[0]['value'][1])
" <<< "$response" 2>/dev/null
  fi
}

prom_query_all() {
  # Query Prometheus instant API; return all results as "instance:device VALUE" lines.
  # Used by fleet mode to get metrics across every monitored host.
  # _LINK_FLAP_TEST_PROM_ALL: path to a canned JSON response file (test hook).
  local query="$1"
  local response
  if [[ -n "${_LINK_FLAP_TEST_PROM_ALL:-}" ]]; then
    response=$(cat "$_LINK_FLAP_TEST_PROM_ALL")
  else
    response=$(curl -sf -G "${PROM_URL}/api/v1/query" \
      --data-urlencode "query=$query" \
      --max-time 5 2>/dev/null) || return 0
  fi
  if command -v jq &>/dev/null; then
    echo "$response" | jq -r '
      .data.result[] |
      ((.metric.instance // "unknown") + ":" + (.metric.device // "unknown")) + " " + .value[1]
    ' 2>/dev/null
  else
    python3 -c "
import json, sys
d = json.loads(sys.stdin.read())
for r in d.get('data', {}).get('result', []):
  inst = r['metric'].get('instance', 'unknown')
  dev  = r['metric'].get('device',   'unknown')
  val  = r['value'][1]
  print(inst + ':' + dev + ' ' + val)
" <<< "$response" 2>/dev/null
  fi
}

prom_targets_health() {
  # Return "down" scrape targets as "INSTANCE LAST_SCRAPE ERROR" lines (space-separated).
  # Silently returns nothing if Prometheus is unreachable or no targets are down.
  # No test hook — fails silently if Prom is absent.
  [[ -z "$PROM_URL" ]] && return 0
  local response
  response=$(curl -sf "${PROM_URL}/api/v1/targets" --max-time 5 2>/dev/null) || return 0
  if command -v jq &>/dev/null; then
    echo "$response" | jq -r '
      .data.activeTargets[] |
      select(.health == "down") |
      [.labels.instance, .lastScrape, (.lastError // "unknown error")] | join("\t")
    ' 2>/dev/null
  else
    python3 -c "
import json, sys
d = json.loads(sys.stdin.read())
for t in d.get('data', {}).get('activeTargets', []):
  if t.get('health') == 'down':
    inst   = t.get('labels', {}).get('instance', 'unknown')
    scrape = t.get('lastScrape', '')
    err    = t.get('lastError', 'unknown error')
    print(inst + '\t' + scrape + '\t' + err)
" <<< "$response" 2>/dev/null
  fi
}

_fleet_print_targets() {
  local data="$1"
  [[ -z "$data" ]] && return
  echo -e "${YELLOW}${BOLD}[UNREACHABLE TARGETS]${RESET}"
  while IFS=$'\t' read -r inst scrape err; do
    [[ -z "$inst" ]] && continue
    local scrape_disp; [[ -z "$scrape" ]] && scrape_disp="never" || scrape_disp="$scrape"
    echo -e "  ${CYAN}${inst}${RESET}  last scrape: ${scrape_disp}  —  ${err}"
  done <<< "$data"
  echo ""
}

fleet_scan_prometheus() {
  local query="increase(node_network_carrier_changes_total[${WINDOW_MINUTES}m])"
  local results
  results=$(prom_query_all "$query") || true

  local flapping_found=0

  while IFS=' ' read -r inst_dev val; do
    [[ -z "$inst_dev" || -z "$val" ]] && continue
    # inst_dev format: "hostname:9100:eth0" — split on last colon to get device name
    local iface="${inst_dev##*:}"
    local inst="${inst_dev%:*}"   # strip last colon+iface → "hostname:9100"
    # Filter virtual interfaces unless -i is set
    if [[ -z "$IFACE_FILTER" ]]; then
      [[ "$iface" =~ ^(lo|veth|virbr|docker|tun|tap|br-) ]] && continue
    else
      [[ "$iface" != "$IFACE_FILTER" ]] && continue
    fi
    # val is a float; compare to threshold
    local above
    above=$(awk -v v="$val" -v t="$FLAP_THRESHOLD" 'BEGIN { print (v+0 >= t+0) ? "yes" : "no" }')
    [[ "$above" != "yes" ]] && continue

    # Enrich: current state and error rates
    local up_val rx_err tx_err
    up_val=$(prom_query "node_network_up{instance=\"${inst}\",device=\"${iface}\"}")
    rx_err=$(prom_query "rate(node_network_receive_errs_total{instance=\"${inst}\",device=\"${iface}\"}[5m])*60")
    tx_err=$(prom_query "rate(node_network_transmit_errs_total{instance=\"${inst}\",device=\"${iface}\"}[5m])*60")

    local state_str="${DIM}unknown${RESET}"
    [[ "$up_val" == "1" ]] && state_str="${GREEN}UP${RESET}"
    [[ "$up_val" == "0" ]] && state_str="${RED}DOWN${RESET}"

    local trans_display
    trans_display=$(printf "%.0f" "$val")

    echo -e "${RED}${BOLD}[FLAPPING]${RESET}  ${BOLD}${inst}${RESET}:${BOLD}${iface}${RESET}"
    echo -e "  Carrier changes : ${RED}${trans_display}${RESET} in last ${WINDOW_MINUTES}m"
    echo -e "  Current state   : ${state_str}"
    [[ -n "$rx_err" ]] && printf "  RX errors       : %.2f/min\n" "$rx_err"
    [[ -n "$tx_err" ]] && printf "  TX errors       : %.2f/min\n" "$tx_err"
    echo ""
    flapping_found=1
    FLAPPING_FOUND=1
  done <<< "$results"

  if [[ "$flapping_found" -eq 0 ]]; then
    echo -e "${GREEN}No flapping detected across fleet in the last ${WINDOW_MINUTES}m.${RESET}"
    echo ""
  fi

  local down_targets
  down_targets=$(prom_targets_health) || true
  _fleet_print_targets "$down_targets"
}

show_prometheus_context() {
  # Print a [Prometheus] enrichment block for the given interface.
  # Skips silently if no Prometheus source is configured, the interface is
  # a synthetic tshark name (stp-*/lacp-*), or no data is returned.
  local iface="$1"
  [[ -z "$PROM_URL" && -z "${_LINK_FLAP_TEST_PROM:-}" ]] && return
  [[ "$iface" =~ ^(stp|lacp)- ]] && return

  local up carrier rx_err tx_err rx_drop tx_drop
  up=$(prom_query "node_network_up{device=\"$iface\"}")
  carrier=$(prom_query "increase(node_network_carrier_changes_total{device=\"$iface\"}[${WINDOW_MINUTES}m])")
  rx_err=$(prom_query "rate(node_network_receive_errs_total{device=\"$iface\"}[5m])*60")
  tx_err=$(prom_query "rate(node_network_transmit_errs_total{device=\"$iface\"}[5m])*60")
  rx_drop=$(prom_query "rate(node_network_receive_drop_total{device=\"$iface\"}[5m])*60")
  tx_drop=$(prom_query "rate(node_network_transmit_drop_total{device=\"$iface\"}[5m])*60")

  [[ -z "$up" && -z "$carrier" ]] && return

  _PROM_REACHED=1
  echo -e "  ${CYAN}[Prometheus]${RESET}"
  if [[ -n "$up" ]]; then
    local s; [[ "$up" == "1" ]] && s="${GREEN}UP${RESET}" || s="${RED}DOWN${RESET}"
    echo -e "    Current state   : $s"
  fi
  [[ -n "$carrier" ]] && printf "    Carrier changes : %.0f in last %sm\n" "$carrier" "$WINDOW_MINUTES"
  [[ -n "$rx_err"  ]] && printf "    RX errors       : %.2f/min\n" "$rx_err"
  [[ -n "$tx_err"  ]] && printf "    TX errors       : %.2f/min\n" "$tx_err"
  [[ -n "$rx_drop" ]] && printf "    RX drops        : %.2f/min\n" "$rx_drop"
  [[ -n "$tx_drop" ]] && printf "    TX drops        : %.2f/min\n" "$tx_drop"
}

show_system_load_at_flap() {
  # Print a [system @ flap time] block showing CPU idle %, memory available %,
  # and load average at the moment flapping began (first_epoch).
  # Requires Prometheus with node_exporter data. Silently skips if unavailable.
  local iface="$1" epoch="$2"
  [[ -z "$PROM_URL" && -z "${_LINK_FLAP_TEST_PROM:-}" ]] && return
  [[ "$iface" =~ ^(stp|lacp)- ]] && return

  local cpu_idle mem_avail load1
  cpu_idle=$(prom_query_at \
    'avg(rate(node_cpu_seconds_total{mode="idle"}[5m]))*100' "$epoch")
  mem_avail=$(prom_query_at \
    'node_memory_MemAvailable_bytes/node_memory_MemTotal_bytes*100' "$epoch")
  load1=$(prom_query_at "node_load1" "$epoch")

  [[ -z "$cpu_idle" && -z "$mem_avail" && -z "$load1" ]] && return

  local flap_ts
  flap_ts=$(date -d "@$epoch" "+%H:%M:%S" 2>/dev/null || echo "unknown")
  echo -e "  ${CYAN}[system @ ${flap_ts}]${RESET}"

  if [[ -n "$cpu_idle" ]]; then
    local cpu_col="$GREEN"
    awk -v v="$cpu_idle" 'BEGIN{exit !(v+0 < 15)}'  && cpu_col="$RED"    || true
    awk -v v="$cpu_idle" 'BEGIN{exit !(v+0>=15 && v+0<30)}' && cpu_col="$YELLOW" || true
    printf "    CPU idle        : ${cpu_col}%.1f%%${RESET}\n" "$cpu_idle"
  fi
  if [[ -n "$mem_avail" ]]; then
    local mem_col="$GREEN"
    awk -v v="$mem_avail" 'BEGIN{exit !(v+0 < 10)}' && mem_col="$YELLOW" || true
    printf "    Memory available: ${mem_col}%.1f%%${RESET}\n" "$mem_avail"
  fi
  [[ -n "$load1" ]] && printf "    Load avg (1m)   : %.2f\n" "$load1"
}

# ── node_exporter ─────────────────────────────────────────────────────────────
_NE_METRICS_CACHE=""
_PROM_REACHED=0

fetch_node_exporter() {
  # Fetch /metrics from node_exporter; cache result in _NE_METRICS_CACHE.
  # Returns 0 if data was fetched, 1 otherwise.
  # _LINK_FLAP_TEST_NODE_EXPORTER: path to canned metrics file (test hook).
  [[ "$NODE_EXPORTER_URL" == "off" ]] && return 1
  if [[ -n "${_LINK_FLAP_TEST_NODE_EXPORTER:-}" ]]; then
    _NE_METRICS_CACHE=$(cat "$_LINK_FLAP_TEST_NODE_EXPORTER" 2>/dev/null || true)
  else
    _NE_METRICS_CACHE=$(curl -sf --max-time 1 "${NODE_EXPORTER_URL}/metrics" 2>/dev/null || true)
  fi
  [[ -n "$_NE_METRICS_CACHE" ]]
}

_ne_val() {
  # Extract a scalar metric value for a specific device from _NE_METRICS_CACHE.
  local metric="$1" iface="$2"
  echo "$_NE_METRICS_CACHE" | awk -v m="$metric" -v d="$iface" '
    /^#/ { next }
    index($0, m "{") == 1 && index($0, "device=\"" d "\"") { print $NF; exit }
  ' 2>/dev/null || true
}

show_node_exporter_context() {
  # Print a [node_exporter] enrichment block for the given interface.
  # Skips if NE data is not cached, iface is synthetic (stp-*/lacp-*), or no data found.
  local iface="$1"
  [[ -z "$_NE_METRICS_CACHE" ]] && return
  [[ "$iface" =~ ^(stp|lacp)- ]] && return

  local up carrier rx_err tx_err rx_drop tx_drop
  up=$(_ne_val node_network_up "$iface")
  carrier=$(_ne_val node_network_carrier_changes_total "$iface")
  rx_err=$(_ne_val node_network_receive_errs_total "$iface")
  tx_err=$(_ne_val node_network_transmit_errs_total "$iface")
  rx_drop=$(_ne_val node_network_receive_drop_total "$iface")
  tx_drop=$(_ne_val node_network_transmit_drop_total "$iface")

  [[ -z "$up" && -z "$carrier" ]] && return

  echo -e "  ${CYAN}[node_exporter]${RESET}"
  if [[ -n "$up" ]]; then
    local s; [[ "$up" == "1" ]] && s="${GREEN}UP${RESET}" || s="${RED}DOWN${RESET}"
    echo -e "    Current state   : $s"
  fi
  [[ -n "$carrier" ]] && printf "    Carrier changes : %s total since boot\n" "$carrier"
  [[ -n "$rx_err"  ]] && printf "    RX errors       : %s total\n" "$rx_err"
  [[ -n "$tx_err"  ]] && printf "    TX errors       : %s total\n" "$tx_err"
  [[ -n "$rx_drop" ]] && printf "    RX drops        : %s total\n" "$rx_drop"
  [[ -n "$tx_drop" ]] && printf "    TX drops        : %s total\n" "$tx_drop"
}

# ── iperf3 ────────────────────────────────────────────────────────────────────
_IPERF3_RESULT_CACHE=""
_IPERF3_BIND_IP=""     # IP used for -B binding (empty = unbound)

run_iperf3() {
  local iface="${1:-}"    # interface being diagnosed (empty in non-wizard mode)
  local local_ip="${2:-}" # IP to bind to (IPv4 or global IPv6; empty = unbound)
  [[ -z "$IPERF3_SERVER" ]] && return 1
  if [[ -n "${_LINK_FLAP_TEST_IPERF3:-}" ]]; then
    _IPERF3_RESULT_CACHE=$(cat "$_LINK_FLAP_TEST_IPERF3" 2>/dev/null || true)
  else
    local bind_args=()
    [[ -n "$local_ip" ]] && bind_args=(-B "$local_ip")
    _IPERF3_RESULT_CACHE=$(iperf3 -c "$IPERF3_SERVER" "${bind_args[@]}" -t 5 --json \
                           2>/dev/null || true)
  fi
  _IPERF3_BIND_IP="$local_ip"
  [[ -n "$_IPERF3_RESULT_CACHE" ]]
}

_iperf3_val() {
  local field="$1"
  [[ -z "$_IPERF3_RESULT_CACHE" ]] && return
  python3 -c "
import json, sys
try:
    d = json.loads(sys.stdin.read())
    v = d
    for p in sys.argv[1].split('.'):
        v = v[p]
    print(v)
except Exception:
    pass
" "$field" <<< "$_IPERF3_RESULT_CACHE" 2>/dev/null || true
}

show_iperf3_context() {
  local iface="$1"
  [[ -z "$_IPERF3_RESULT_CACHE" ]] && return
  [[ "$iface" =~ ^(stp|lacp)- ]] && return

  local bps retransmits
  bps=$(_iperf3_val "end.sum_sent.bits_per_second")
  retransmits=$(_iperf3_val "end.sum_sent.retransmits")

  [[ -z "$bps" && -z "$retransmits" ]] && return

  if [[ -n "$_IPERF3_BIND_IP" ]]; then
    echo -e "  ${CYAN}[iperf3]${RESET}  → ${IPERF3_SERVER}  (via ${iface} ${_IPERF3_BIND_IP})"
  else
    echo -e "  ${CYAN}[iperf3]${RESET}  → ${IPERF3_SERVER}"
  fi
  if [[ -n "$bps" ]]; then
    local mbps
    mbps=$(python3 -c "import sys; print(f'{float(sys.argv[1])/1e6:.1f}')" "$bps" 2>/dev/null || echo "?")
    printf "    Bandwidth       : %s Mbps\n" "$mbps"
  fi
  if [[ -n "$retransmits" ]]; then
    if [[ "$retransmits" =~ ^[0-9]+$ ]] && [[ "$retransmits" -gt 0 ]]; then
      echo -e "    Retransmits     : ${YELLOW}${retransmits}${RESET}"
    else
      echo    "    Retransmits     : ${retransmits}"
    fi
  fi
}

parse_events() {
  # Reads raw log lines from stdin, writes "epoch iface STATE" to stdout.
  # Implemented entirely in awk — no subshell spawning per line.
  # Timestamp conversion is handled by calling date(1) once per unique ts string
  # via a small shell wrapper piped back in; but for speed we pass the raw ts
  # through and convert in a post-processing step with a single date invocation.
  #
  # Actually: awk cannot call date(), so we emit "ts_raw iface STATE" lines and
  # convert timestamps in a second awk+date pass.  This keeps it to two fast
  # passes rather than N subshell spawns.

  awk -v iface_filter="$IFACE_FILTER" '
  {
    line = $0
    iface = ""
    state = ""

    # ── Timestamp: first field ──────────────────────────────────────────────
    ts_raw = $1

    # Reconstruct syslog-style "Mon DD HH:MM:SS" timestamps (fields 1-3)
    # ISO 8601 timestamps start with a digit
    if (ts_raw !~ /^[0-9]{4}/) {
      ts_raw = $1 " " $2 " " $3
    }

    # ── Pattern matching (case-insensitive via tolower) ─────────────────────
    lower = tolower(line)

    # Kernel: "<iface>: NIC Link is Up/Down"
    if (match(lower, /[a-z][a-z0-9_-]+: nic link is (up|down)/)) {
      seg = substr(lower, RSTART, RLENGTH)
      split(seg, a, ": nic link is ")
      iface = a[1]
      state = (a[2] ~ /^up/) ? "UP" : "DOWN"

    # Kernel: "<iface>: Link is Up/Down"  (avoid matching "NIC Link")
    } else if (match(lower, /[a-z][a-z0-9_-]+: link is (up|down)/) &&
               lower !~ /nic link/) {
      seg = substr(lower, RSTART, RLENGTH)
      split(seg, a, ": link is ")
      iface = a[1]
      state = (a[2] ~ /^up/) ? "UP" : "DOWN"

    # Kernel: "<iface>: carrier acquired/lost"
    } else if (match(lower, /[a-z][a-z0-9_-]+: carrier (acquired|lost)/)) {
      seg = substr(lower, RSTART, RLENGTH)
      split(seg, a, ": carrier ")
      iface = a[1]
      state = (a[2] ~ /^acq/) ? "UP" : "DOWN"

    # systemd-networkd: "<iface>: Gained/Lost carrier"
    } else if (match(lower, /[a-z][a-z0-9_-]+: (gained|lost) carrier/)) {
      seg = substr(lower, RSTART, RLENGTH)
      n = split(seg, a, ": ")
      iface = a[1]
      state = (a[2] ~ /^gained/) ? "UP" : "DOWN"

    # systemd-networkd: "<iface>: Link UP/DOWN"
    } else if (match(lower, /[a-z][a-z0-9_-]+: link (up|down)/) &&
               lower !~ /nic link/ && lower !~ /link is/) {
      seg = substr(lower, RSTART, RLENGTH)
      split(seg, a, ": link ")
      iface = a[1]
      state = (a[2] ~ /^up/) ? "UP" : "DOWN"

    # NetworkManager: "device (<iface>): link connected/disconnected"
    } else if (match(lower, /device \([a-z][a-z0-9_-]+\): link (connected|disconnected)/)) {
      seg = substr(lower, RSTART, RLENGTH)
      if (match(seg, /\([a-z][a-z0-9_-]+\)/)) {
        iface = substr(seg, RSTART+1, RLENGTH-2)
      }
      state = (seg ~ /link connected$/) ? "UP" : "DOWN"

    # NetworkManager: "device (<iface>): state change: ... -> <new_state>"
    } else if (lower ~ /device \([a-z][a-z0-9_-]+\): state change:/) {
      if (match(lower, /\([a-z][a-z0-9_-]+\)/)) {
        iface = substr(lower, RSTART+1, RLENGTH-2)
      }
      # Extract last "-> word"
      arrow = ""
      tmp = lower
      while (match(tmp, /-> [a-z]+/)) {
        arrow = substr(tmp, RSTART, RLENGTH)
        tmp = substr(tmp, RSTART + RLENGTH)
      }
      sub(/^-> /, "", arrow)
      if (arrow ~ /^(activated|connected)$/)                        state = "UP"
      else if (arrow ~ /^(unavailable|unmanaged|disconnected|deactivating|failed)$/) state = "DOWN"
    }

    if (iface == "" || state == "") next

    # Skip virtual / container interfaces unless a specific filter is set
    if (iface_filter == "") {
      if (iface ~ /^(lo|veth|virbr|docker|tun|tap)/ || iface ~ /^br-/) next
    } else {
      if (iface != iface_filter) next
    }

    print ts_raw "\t" iface "\t" state
  }
  ' | \
  # Second pass: convert ts_raw → epoch using date(1) once per unique timestamp
  awk -F'\t' '
  BEGIN { now = systime() }
  {
    ts  = $1
    iface = $2
    state = $3

    if (!(ts in epoch_cache)) {
      ts_safe = ts
      gsub(/[^A-Za-z0-9 :+TZ-]/, "", ts_safe)
      cmd = "date -d \047" ts_safe "\047 +%s 2>/dev/null || echo 0"
      cmd | getline result
      close(cmd)
      # Guard against syslog timestamps without a year (e.g. "Dec 31 14:00:00").
      # date(1) picks the current year, producing a future epoch when the log entry
      # is from December and the tool runs in January. Pull it back one year.
      if ((result + 0) > (now + 86400))
        result = result - 31536000
      epoch_cache[ts] = result
    }
    ep = epoch_cache[ts]
    if (ep != "0" && ep != "") print ep " " iface " " state
  }
  '
}

# ── Step 2: Populate TMPFILE ──────────────────────────────────────────────────
LOG_SOURCE="journald"

if [[ "$FLEET_MODE" -eq 0 ]]; then
  if [[ -n "${_LINK_FLAP_TEST_INPUT:-}" ]]; then
    # Test hook: bypass journald/syslog and read from a supplied file.
    # Set by the test suite only — not a documented end-user option.
    LOG_SOURCE="test-input"
    collect_from_syslog "$_LINK_FLAP_TEST_INPUT" | parse_events >> "$TMPFILE"
  elif [[ -n "${_LINK_FLAP_TEST_TSHARK:-}" ]]; then
    LOG_SOURCE="test-tshark"
    if [[ -n "$IFACE_FILTER" ]]; then
      awk -v f="$IFACE_FILTER" '$2 == f' "$_LINK_FLAP_TEST_TSHARK" >> "$TMPFILE"
    else
      cat "$_LINK_FLAP_TEST_TSHARK" >> "$TMPFILE"
    fi
  elif [[ -n "$PCAP_FILE" ]]; then
    LOG_SOURCE="tshark ($PCAP_FILE)"
    collect_from_tshark "$PCAP_FILE" >> "$TMPFILE"
  elif command -v journalctl &>/dev/null; then
    collect_from_journald | parse_events >> "$TMPFILE"
  else
    LOG_SOURCE="syslog files"
    for f in /var/log/syslog /var/log/kern.log; do
      collect_from_syslog "$f" | parse_events >> "$TMPFILE"
    done
  fi

  # Remove duplicate lines (same epoch + iface + state from multiple sources)
  sort -u "$TMPFILE" -o "$TMPFILE"

  # Apply --since / --until epoch filter when a date range is specified
  if [[ -n "$SINCE_EPOCH" || -n "$UNTIL_EPOCH" ]]; then
    _RANGE_NOW=$(date +%s)
    awk -v s="${SINCE_EPOCH:-0}" -v u="${UNTIL_EPOCH:-$_RANGE_NOW}" \
      '$1+0 >= s+0 && $1+0 <= u+0' "$TMPFILE" > "${TMPFILE}.range"
    mv "${TMPFILE}.range" "$TMPFILE"
  fi
fi

# ── Step 3: Analyse for flapping ─────────────────────────────────────────────
# For each interface: count state transitions, report if >= FLAP_THRESHOLD

# Probe node_exporter once; result cached for wizard and per-interface blocks below
fetch_node_exporter || true
# In wizard mode: auto-detect local bind IP and remote peer IP for iperf3.
# No user prompt needed — both ends are resolved from the interface.
if [[ -n "$DIAG_IFACE" ]]; then
  # Local bind IP: IPv4 preferred, fall back to global/ULA IPv6 (skip link-local)
  _iface_addr_raw=$(ip addr show "$DIAG_IFACE" 2>/dev/null || true)
  _iperf3_local_ip=$(echo "$_iface_addr_raw" \
    | grep -oP 'inet \K[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' | head -1 || true)
  if [[ -z "$_iperf3_local_ip" ]]; then
    _iperf3_local_ip=$(echo "$_iface_addr_raw" \
      | grep 'inet6' | grep -v 'scope link' \
      | grep -oP 'inet6 \K[0-9a-f:]+' | head -1 || true)
  fi

  # Remote peer IP (only auto-set if not already configured via -b or config)
  if [[ -z "$IPERF3_SERVER" ]]; then
    # Try LLDP management IP first (most accurate — IP of the directly connected device)
    if command -v lldpctl &>/dev/null; then
      _lldp_peer_raw=$(lldpctl "$DIAG_IFACE" 2>/dev/null || true)
      IPERF3_SERVER=$(echo "$_lldp_peer_raw" \
        | grep -oP '(?i)mgmtip:\s*\K[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' | head -1 || true)
    fi
    # Fall back to default gateway (next-hop router on this interface)
    if [[ -z "$IPERF3_SERVER" ]]; then
      IPERF3_SERVER=$(ip route show dev "$DIAG_IFACE" 2>/dev/null \
        | awk '/^default/{print $3; exit}' || true)
    fi
  fi

  run_iperf3 "$DIAG_IFACE" "$_iperf3_local_ip" || true
else
  run_iperf3 || true
fi

if [[ -n "$DIAG_IFACE" ]]; then
  run_wizard "$DIAG_IFACE"
  _flap_what_next 0
  exit 0
fi

FLAPPING_FOUND=0
FLAPPING_COUNT=0
FLAPPING_IFACES=()
declare -A FLAPPING_TRANSITIONS=()

# Get unique interfaces from TMPFILE
mapfile -t IFACES < <(awk '{print $2}' "$TMPFILE" | sort -u)

# ── JSON mode: suppress human-readable output ───────────────────────────────
# Save real stdout to fd 3 and redirect all subsequent echo/printf to /dev/null.
# Structured data is collected into _JSON_* accumulators and emitted at exit.
if [[ "$JSON_MODE" -eq 1 ]]; then
  exec 3>&1
  exec 1>/dev/null
fi
_JSON_LOG_SOURCE="$LOG_SOURCE"

# ── Test-mode warning ─────────────────────────────────────────────────────────
# Print an unmissable banner whenever any synthetic data hook is active, so
# there is zero ambiguity between a test run and a real system scan.
_TEST_ACTIVE=0
[[ -n "${_LINK_FLAP_TEST_INPUT:-}"         ]] && _TEST_ACTIVE=1
[[ -n "${_LINK_FLAP_TEST_TSHARK:-}"        ]] && _TEST_ACTIVE=1
[[ -n "${_LINK_FLAP_TEST_PROM:-}"          ]] && _TEST_ACTIVE=1
[[ -n "${_LINK_FLAP_TEST_NODE_EXPORTER:-}" ]] && _TEST_ACTIVE=1
[[ -n "${_LINK_FLAP_TEST_IPERF3:-}"        ]] && _TEST_ACTIVE=1
[[ -n "${_LINK_FLAP_TEST_WIZARD_DIR:-}"    ]] && _TEST_ACTIVE=1
[[ -n "${_LINK_FLAP_TEST_PROM_ALL:-}"      ]] && _TEST_ACTIVE=1

if [[ $_TEST_ACTIVE -eq 1 ]]; then
  echo ""
  echo -e "${YELLOW}${BOLD}╔══════════════════════════════════════════════════════╗${RESET}"
  echo -e "${YELLOW}${BOLD}║  WARNING: SYNTHETIC TEST DATA — NOT REAL SYSTEM DATA ║${RESET}"
  echo -e "${YELLOW}${BOLD}╚══════════════════════════════════════════════════════╝${RESET}"
  [[ -n "${_LINK_FLAP_TEST_INPUT:-}"         ]] && echo -e "${YELLOW}  Logs    : synthetic file (not journald/syslog)${RESET}"
  [[ -n "${_LINK_FLAP_TEST_TSHARK:-}"        ]] && echo -e "${YELLOW}  tshark  : synthetic packet data (not a real pcap)${RESET}"
  [[ -n "${_LINK_FLAP_TEST_PROM:-}"          ]] && echo -e "${YELLOW}  Prom    : canned API response (not a real Prometheus)${RESET}"
  [[ -n "${_LINK_FLAP_TEST_NODE_EXPORTER:-}" ]] && echo -e "${YELLOW}  NE      : canned metrics (not a real node_exporter)${RESET}"
  [[ -n "${_LINK_FLAP_TEST_IPERF3:-}"        ]] && echo -e "${YELLOW}  iperf3  : canned JSON (not a real iperf3 run)${RESET}"
  [[ -n "${_LINK_FLAP_TEST_WIZARD_DIR:-}"    ]] && echo -e "${YELLOW}  Wizard  : mocked sysfs/ethtool (not real hardware)${RESET}"
  [[ -n "${_LINK_FLAP_TEST_PROM_ALL:-}"      ]] && echo -e "${YELLOW}  Fleet   : canned Prom multi-result (not a real Prometheus)${RESET}"
fi

echo ""
if [[ "$FLEET_MODE" -eq 1 ]]; then
  echo -e "${BOLD}Link Flap Detector${RESET} — ${BOLD}fleet mode${RESET}"
else
  echo -e "${BOLD}Link Flap Detector${RESET} — source: ${LOG_SOURCE}"
fi
if [[ -n "$SINCE_EPOCH" ]]; then
  _since_disp=$(date -d "@$SINCE_EPOCH" "+%Y-%m-%d %H:%M:%S")
  _until_disp=$(date -d "@${UNTIL_EPOCH:-$(date +%s)}" "+%Y-%m-%d %H:%M:%S")
  echo -e "Window: ${_since_disp} → ${_until_disp}  |  Flap threshold: ${FLAP_THRESHOLD} transitions"
else
  echo -e "Window: last ${WINDOW_MINUTES}m  |  Flap threshold: ${FLAP_THRESHOLD} transitions"
fi
[[ -n "$IFACE_FILTER" ]] && echo -e "Interface filter: ${CYAN}${IFACE_FILTER}${RESET}"
[[ -n "$PROM_URL" ]] && echo -e "Prometheus: ${CYAN}${PROM_URL}${RESET}"
[[ -n "$_NE_METRICS_CACHE" ]] && echo -e "node_exporter: ${CYAN}${NODE_EXPORTER_URL}${RESET}"
[[ -n "$_IPERF3_RESULT_CACHE" ]] && echo -e "iperf3: ${CYAN}${IPERF3_SERVER}${RESET}"
[[ -n "$FOLLOW_SECONDS" ]] && echo -e "Follow: every ${CYAN}${FOLLOW_SECONDS}s${RESET}  (Ctrl-C to stop)"
[[ -n "$WEBHOOK_URL" ]] && echo -e "Webhook: ${CYAN}${WEBHOOK_URL}${RESET}"
echo ""

# Fleet mode: query Prometheus directly — bypass per-interface local-log analysis
if [[ "$FLEET_MODE" -eq 1 ]]; then
  fleet_scan_prometheus
  exit $(( FLAPPING_FOUND ))
fi

if [[ ${#IFACES[@]} -eq 0 ]]; then
  echo -e "${GREEN}No link state events found in the log window.${RESET}"
  echo ""
  if [[ -n "$FOLLOW_SECONDS" ]]; then
    # Fire "cleared" for any ifaces that were flapping last cycle but aren't now
    if [[ -n "$WEBHOOK_URL" ]]; then
      for _pi in ${_FLAP_PREV_FLAPPING:-}; do
        _send_webhook "$WEBHOOK_URL" "cleared" "$_pi"
      done
    fi
    echo -e "${DIM}--- next scan in ${FOLLOW_SECONDS}s (Ctrl-C to stop) ---${RESET}"
    sleep "$FOLLOW_SECONDS"
    exec env _FLAP_FOLLOW_CHILD=1 _FLAP_PREV_FLAPPING="" "$0" "${_ORIG_ARGS[@]}"
  fi
  if [[ "$JSON_MODE" -eq 1 ]]; then
    exec 1>&3
    _j_ts=$(date -u "+%Y-%m-%dT%H:%M:%S+0000")
    _j_since="null"
    [[ -n "${SINCE_EPOCH:-}" ]] && _j_since="\"$(date -d "@$SINCE_EPOCH" -u "+%Y-%m-%dT%H:%M:%S+0000" 2>/dev/null)\""
    _j_until="null"
    [[ -n "${UNTIL_EPOCH:-}" ]] && _j_until="\"$(date -d "@$UNTIL_EPOCH" -u "+%Y-%m-%dT%H:%M:%S+0000" 2>/dev/null)\""
    python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
json.dump(data, sys.stdout, indent=2)
print()
" <<EOF
{
  "version": "${VERSION}",
  "timestamp": "${_j_ts}",
  "config": {
    "window_minutes": ${WINDOW_MINUTES},
    "flap_threshold": ${FLAP_THRESHOLD},
    "iface_filter": $(if [[ -n "$IFACE_FILTER" ]]; then echo "\"${IFACE_FILTER}\""; else echo "null"; fi),
    "log_source": "${_JSON_LOG_SOURCE}",
    "since": ${_j_since},
    "until": ${_j_until}
  },
  "interfaces": [],
  "correlation": {"detected": false},
  "summary": {
    "flapping_found": false,
    "flapping_count": 0,
    "flapping_interfaces": []
  }
}
EOF
  fi
  exit 0
fi

for iface in "${IFACES[@]}"; do
  # Extract events for this interface, sorted by time
  mapfile -t EVENTS < <(grep -F -- " $iface " "$TMPFILE" | sort -n)

  count=${#EVENTS[@]}
  [[ "$count" -lt 2 ]] && continue   # Need at least 2 events to detect flapping

  # Count transitions (state changes between consecutive events)
  transitions=0
  prev_state=""
  declare -a event_lines=()

  for evt in "${EVENTS[@]}"; do
    IFS=' ' read -r epoch _evt_iface state <<< "$evt"
    ts_human=$(date -d "@$epoch" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "unknown")

    _sc="$RED"; [[ "$state" == "UP" ]] && _sc="$GREEN"
    event_lines+=("  ${DIM}${ts_human}${RESET}  ${_sc}${state}${RESET}")

    if [[ -n "$prev_state" && "$state" != "$prev_state" ]]; then
      (( transitions++ )) || true
    fi
    prev_state="$state"
  done

  # First and last event timestamps
  first_epoch=$(echo "${EVENTS[0]}"  | awk '{print $1}')
  last_epoch=$(echo  "${EVENTS[-1]}" | awk '{print $1}')
  first_ts=$(date -d "@$first_epoch" "+%H:%M:%S" 2>/dev/null || echo "?")
  last_ts=$(date -d  "@$last_epoch"  "+%H:%M:%S" 2>/dev/null || echo "?")
  span=$(( last_epoch - first_epoch ))
  span_str="${span}s"
  [[ "$span" -ge 60 ]] && span_str="$(( span / 60 ))m $(( span % 60 ))s"

  # ── JSON: collect per-interface data ─────────────────────────────────────
  if [[ "$JSON_MODE" -eq 1 ]]; then
    _j_status="active"
    [[ "$transitions" -ge "$FLAP_THRESHOLD" ]] && _j_status="flapping"
    _j_events=""
    for evt in "${EVENTS[@]}"; do
      IFS=' ' read -r _je _ji _js <<< "$evt"
      _je_iso=$(date -d "@$_je" -u "+%Y-%m-%dT%H:%M:%S+0000" 2>/dev/null || echo "unknown")
      [[ -n "$_j_events" ]] && _j_events+=","
      _j_events+="{\"epoch\":${_je},\"timestamp\":\"${_je_iso}\",\"state\":\"${_js}\"}"
    done
    _j_first_iso=$(date -d "@$first_epoch" -u "+%Y-%m-%dT%H:%M:%S+0000" 2>/dev/null || echo "unknown")
    _j_last_iso=$(date -d "@$last_epoch" -u "+%Y-%m-%dT%H:%M:%S+0000" 2>/dev/null || echo "unknown")
    _JSON_IFACES+=("{\"name\":\"${iface}\",\"status\":\"${_j_status}\",\"transitions\":${transitions},\"event_count\":${count},\"first_event\":\"${_j_first_iso}\",\"last_event\":\"${_j_last_iso}\",\"span_seconds\":${span},\"events\":[${_j_events}]}")
  fi

  if [[ "$transitions" -ge "$FLAP_THRESHOLD" ]]; then
    FLAPPING_FOUND=1
    (( FLAPPING_COUNT++ )) || true
    FLAPPING_IFACES+=("$iface")
    FLAPPING_TRANSITIONS["$iface"]=$transitions
    echo -e "${RED}${BOLD}[FLAPPING]${RESET} ${BOLD}${iface}${RESET}"
    echo -e "  Transitions : ${RED}${transitions}${RESET}  |  Events: ${count}  |  Span: ${first_ts}–${last_ts} (${span_str})"
    if [[ "$VERBOSE" -eq 1 ]]; then
      for el in "${event_lines[@]}"; do
        echo -e "$el"
      done
    fi
    show_prometheus_context "$iface"
    show_system_load_at_flap "$iface" "$first_epoch"
    show_node_exporter_context "$iface"
    show_iperf3_context "$iface"
    echo ""
  else
    if [[ "$VERBOSE" -eq 1 ]]; then
      echo -e "${YELLOW}${BOLD}[ACTIVE]${RESET}  ${BOLD}${iface}${RESET} — ${transitions} transition(s) in window (below threshold)"
      for el in "${event_lines[@]}"; do
        echo -e "$el"
      done
      show_prometheus_context "$iface"
      show_system_load_at_flap "$iface" "$first_epoch"
      show_node_exporter_context "$iface"
      show_iperf3_context "$iface"
      echo ""
    fi
  fi
done

# Warn if Prometheus was configured but returned no data.
# Distinguish two cases: Prometheus unreachable vs. connected but no metrics for this interface.
if [[ -n "$PROM_URL" ]] && [[ "$_PROM_REACHED" -eq 0 ]]; then
  _prom_connected=0
  if [[ -n "${_LINK_FLAP_TEST_PROM:-}" ]]; then
    # Test hook active — treat as a successful Prometheus response (hook simulates real data path)
    _prom_connected=1
  elif curl -sf --max-time 3 "${PROM_URL}/api/v1/query?query=1%2B1" >/dev/null 2>&1; then
    _prom_connected=1
  fi
  if [[ "$_prom_connected" -eq 1 ]]; then
    echo -e "${DIM}(Prometheus connected but no network metrics found for this interface — check that node_exporter is running and exposing /sys/class/net metrics)${RESET}"
  else
    echo -e "${DIM}(Prometheus at ${PROM_URL} returned no data — verify connectivity)${RESET}"
  fi
  echo ""
fi

# ── Cross-interface correlation ────────────────────────────────────────────────
# If 2+ interfaces are flapping, check whether any of their events fell in the
# same 10-second bucket — a strong hint of a common upstream cause.
if [[ "$FLAPPING_COUNT" -ge 2 ]]; then
  _corr=$(awk '
  {
    bucket = int($1 / 10) * 10
    key    = bucket SUBSEP $2
    if (!(key in seen)) {
      seen[key] = 1
      count[bucket]++
      if (count[bucket] >= 2) { print "yes"; exit }
    }
  }
  ' "$TMPFILE")
  if [[ "$_corr" == "yes" ]]; then
    _JSON_CORRELATION="true"
    echo -e "  ${YELLOW}[CORRELATED]${RESET} Multiple interfaces had events in the same 10-second window."
    echo -e "  ${DIM}Possible shared cause: switch reboot, upstream link failure, power event, or broadcast storm.${RESET}"
    echo ""
  fi
fi

if [[ "$FLAPPING_FOUND" -eq 0 ]]; then
  echo -e "${GREEN}No flapping detected${RESET} in the last ${WINDOW_MINUTES} minutes (threshold: ${FLAP_THRESHOLD} transitions)."
  echo ""
else
  _plural="s"; [[ "$FLAPPING_COUNT" -eq 1 ]] && _plural=""
  echo -e "${BOLD}Summary:${RESET} ${RED}${FLAPPING_COUNT} interface${_plural} flapping${RESET} in the last ${WINDOW_MINUTES} minutes."
  echo ""
fi

# ── Auto-diagnostic wizard ─────────────────────────────────────────────────────
# When flapping is found and no explicit -d was given, automatically run the
# diagnostic wizard on each flapping interface so the user gets actionable
# findings in a single command.
# Skipped in test mode (_LINK_FLAP_TEST_INPUT / _LINK_FLAP_TEST_TSHARK set)
# unless _LINK_FLAP_TEST_WIZARD_DIR is also provided for mocked sysfs.
if [[ ${#FLAPPING_IFACES[@]} -gt 0 ]] && {
     [[ -z "${_LINK_FLAP_TEST_INPUT:-}" && -z "${_LINK_FLAP_TEST_TSHARK:-}" ]] ||
     [[ -n "${_LINK_FLAP_TEST_WIZARD_DIR:-}" ]]; }; then
  for _auto_iface in "${FLAPPING_IFACES[@]}"; do
    echo -e "${BOLD}──── Diagnostic: ${CYAN}${_auto_iface}${RESET}${BOLD} ────${RESET}"
    echo ""
    run_wizard "$_auto_iface"
  done
fi

# ── Webhook state-change alerts ───────────────────────────────────────────────
_FLAP_NEXT_FLAPPING=""
if [[ -n "$WEBHOOK_URL" ]]; then
  declare -A _prev_flapping_set=()
  for _pi in ${_FLAP_PREV_FLAPPING:-}; do
    _prev_flapping_set["$_pi"]=1
  done

  for _wi in "${FLAPPING_IFACES[@]}"; do
    if [[ -z "${_prev_flapping_set[$_wi]:-}" ]]; then
      _send_webhook "$WEBHOOK_URL" "flapping" "$_wi" "${FLAPPING_TRANSITIONS[$_wi]:-}"
    fi
  done

  if [[ -n "$FOLLOW_SECONDS" ]]; then
    declare -A _curr_flapping_set=()
    for _wi in "${FLAPPING_IFACES[@]}"; do _curr_flapping_set["$_wi"]=1; done
    for _pi in "${!_prev_flapping_set[@]}"; do
      if [[ -z "${_curr_flapping_set[$_pi]:-}" ]]; then
        _send_webhook "$WEBHOOK_URL" "cleared" "$_pi"
      fi
    done
  fi

  _FLAP_NEXT_FLAPPING="${FLAPPING_IFACES[*]:-}"
fi

if [[ -n "$FOLLOW_SECONDS" ]]; then
  echo -e "${DIM}--- next scan in ${FOLLOW_SECONDS}s (Ctrl-C to stop) ---${RESET}"
  sleep "$FOLLOW_SECONDS"
  exec env _FLAP_FOLLOW_CHILD=1 _FLAP_PREV_FLAPPING="${_FLAP_NEXT_FLAPPING:-}" "$0" "${_ORIG_ARGS[@]}"
fi
# ── JSON output emission ─────────────────────────────────────────────────────
if [[ "$JSON_MODE" -eq 1 ]]; then
  exec 1>&3  # restore real stdout
  _j_ts=$(date -u "+%Y-%m-%dT%H:%M:%S+0000")
  _j_ifaces_arr=""
  for _ji in "${_JSON_IFACES[@]+"${_JSON_IFACES[@]}"}"; do
    [[ -n "$_j_ifaces_arr" ]] && _j_ifaces_arr+=","
    _j_ifaces_arr+="$_ji"
  done
  _j_flapping_arr=""
  for _jf in "${FLAPPING_IFACES[@]+"${FLAPPING_IFACES[@]}"}"; do
    [[ -n "$_j_flapping_arr" ]] && _j_flapping_arr+=","
    _j_flapping_arr+="\"${_jf}\""
  done
  _j_corr="false"
  [[ "$_JSON_CORRELATION" == "true" ]] && _j_corr="true"
  _j_since="null"
  [[ -n "${SINCE_EPOCH:-}" ]] && _j_since="\"$(date -d "@$SINCE_EPOCH" -u "+%Y-%m-%dT%H:%M:%S+0000" 2>/dev/null)\""
  _j_until="null"
  [[ -n "${UNTIL_EPOCH:-}" ]] && _j_until="\"$(date -d "@$UNTIL_EPOCH" -u "+%Y-%m-%dT%H:%M:%S+0000" 2>/dev/null)\""
  python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
json.dump(data, sys.stdout, indent=2)
print()
" <<EOF
{
  "version": "${VERSION}",
  "timestamp": "${_j_ts}",
  "config": {
    "window_minutes": ${WINDOW_MINUTES},
    "flap_threshold": ${FLAP_THRESHOLD},
    "iface_filter": $(if [[ -n "$IFACE_FILTER" ]]; then echo "\"${IFACE_FILTER}\""; else echo "null"; fi),
    "log_source": "${_JSON_LOG_SOURCE}",
    "since": ${_j_since},
    "until": ${_j_until}
  },
  "interfaces": [${_j_ifaces_arr}],
  "correlation": {
    "detected": ${_j_corr}
  },
  "summary": {
    "flapping_found": $(if [[ "$FLAPPING_FOUND" -eq 1 ]]; then echo "true"; else echo "false"; fi),
    "flapping_count": ${FLAPPING_COUNT},
    "flapping_interfaces": [${_j_flapping_arr}]
  }
}
EOF
  exit $(( FLAPPING_FOUND ))
fi

_flap_what_next "$(( FLAPPING_FOUND ))"
exit $(( FLAPPING_FOUND ))
