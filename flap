#!/usr/bin/env bash
# flap
# Detect network interface link flapping by parsing system logs.
# Supports: journald (primary), /var/log/syslog, /var/log/kern.log, /var/log/messages
# Covers:   kernel NIC drivers (virtio_net, e1000e, igb, tg3, ixgbe, bnxt, ...),
#           systemd-networkd, NetworkManager
# Platform: Ubuntu 24.04 (systemd), also works on 20.04 / 22.04
#
# Usage:
#   ./flap [OPTIONS]
#
# Options:
#   -w MINUTES    Time window to scan back from now (default: 60)
#   -t COUNT      Number of transitions to consider flapping (default: 3)
#                 Per-interface: -t eth0:10,eth1:5 (overrides global for named interfaces)
#   -i IFACE      Limit output to a specific interface (e.g. eth0, ens18)
#   -p PCAP_FILE  Analyse a packet capture file with tshark (requires tshark)
#   -m URL        Prometheus base URL (prompts interactively on first TTY run if unset;
#                 saved for future runs in ~/.config/link-flap/config)
#   -n URL        node_exporter metrics URL (default: http://localhost:9100; 'off' to disable)
#   -b SERVER     iperf3 server for 5s bandwidth+retransmit test (saved for future runs)
#   --iperf3-port PORT     iperf3 port (default 5201; saved)
#   --iperf3-duration SECS iperf3 test duration (default 5; saved)
#   --iperf3-udp           Use UDP protocol for iperf3 (default TCP; saved)
#   --iperf3-bitrate RATE  iperf3 bandwidth limit (e.g. 100M; saved)
#   --iperf3-server        Start as iperf3 server (foreground, Ctrl-C to stop)
#   -d IFACE      Run diagnostic wizard for IFACE — full report of likely causes and fixes
#   -r BACKUP_ID  Restore config files from a saved backup (use 'list' to show all backups)
#   -f SECONDS    Follow mode: re-run every N seconds (Ctrl-C to stop)
#   -W URL        Webhook URL for flap/clear alerts (Slack, Discord, or generic);
#                 saved for future runs. Fires on state changes only in follow mode.
#   -j            JSON output — emit a single JSON object instead of human-readable text
#   -v            Verbose — show every individual up/down event
#   -h            Show this help
#   --fix         Auto-apply safe single-command fixes from wizard findings (prompts in TTY)
#   --fix-dry-run Preview fixes without applying (sets --fix + --dry-run)
#   --dry-run     When combined with --fix, show what would be applied without executing
#   -H HOST       Run on a remote machine over SSH (e.g. -H user@192.168.1.1)
#   --export FILE Write Prometheus textfile metrics to FILE (for node_exporter textfile collector)
#   --reports     List and summarise saved wizard reports
#   --log-file F  Append output to FILE instead of stdout (ANSI auto-disabled)
#   --quiet       Suppress all stdout output; exit code still reflects flapping
#   --fleet       Fleet mode: query Prometheus for flapping across all monitored hosts (requires -m)
#   --dut IFACE   Device-under-test interface; wizard compares it against the primary interface
#                 to determine whether the fault is in the DUT or in this computer's network
#   --update      Update flap to the latest version from GitHub and exit
#   --config ACTION  Config: 'show' prints saved values, 'reset' clears all
#   --events [N|all|DATE]  Show recent entries from the persistent event log (default: last 20)
#   --since DATE  Scan from DATE (overrides -w). Accepts 'YYYY-MM-DD' or 'YYYY-MM-DD HH:MM:SS'
#   --until DATE  Scan up to DATE (default: now). Same format as --since.
#                 Date-only --since defaults to 00:00:00; date-only --until defaults to 23:59:59.
#
# Environment overrides (same as flags):
#   WINDOW_MINUTES, FLAP_THRESHOLD, IFACE_FILTER

set -euo pipefail

# ── Exit code contract ──────────────────────────────────────────────────────
#   exit 0 — no flapping detected
#   exit 1 — flapping detected
#   exit 2 — tool/environment error (bad args, missing deps, I/O failure)
# Automation (cron, scripts) can reliably distinguish "all clear" from
# "flapping" from "the tool itself failed."

if [[ "${BASH_VERSINFO[0]}" -lt 4 ]]; then
  echo "Error: bash 4+ required (found ${BASH_VERSION})." >&2; exit 2
fi

# ── Source library modules ─────────────────────────────────────────────────────
_SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
_LIB_DIR=""
if [[ -d "${_SCRIPT_DIR}/lib" ]]; then
  _LIB_DIR="${_SCRIPT_DIR}/lib"
elif [[ -d "${_SCRIPT_DIR}/../lib/link-flap" ]]; then
  _LIB_DIR="${_SCRIPT_DIR}/../lib/link-flap"
fi
if [[ -n "$_LIB_DIR" ]]; then
  for _lib in "$_LIB_DIR"/*.sh; do
    [[ -f "$_lib" ]] || continue
    # shellcheck source=/dev/null
    source "$_lib"
  done
  unset _lib
fi
unset _LIB_DIR

VERSION="2026.03.05.2"

# ── Defaults ──────────────────────────────────────────────────────────────────
WINDOW_MINUTES=${WINDOW_MINUTES:-60}
# Default: 3 transitions. No universal standard; Cisco IOS defaults to 5 per 10s.
# Configurable via -t because the right value depends on link type and environment.
FLAP_THRESHOLD=${FLAP_THRESHOLD:-3}
IFACE_FILTER=${IFACE_FILTER:-""}
PCAP_FILE=${PCAP_FILE:-""}
PROM_URL=${PROM_URL:-""}
NODE_EXPORTER_URL="${NODE_EXPORTER_URL:-http://localhost:9100}"
IPERF3_SERVER="${IPERF3_SERVER:-}"
IPERF3_PORT="${IPERF3_PORT:-5201}"
IPERF3_DURATION="${IPERF3_DURATION:-5}"
IPERF3_PROTOCOL="${IPERF3_PROTOCOL:-}"        # empty=tcp, "udp"=udp
IPERF3_BITRATE="${IPERF3_BITRATE:-}"          # empty=unlimited(TCP)/1M(UDP default)
FOLLOW_SECONDS="${FOLLOW_SECONDS:-}"
WEBHOOK_URL="${WEBHOOK_URL:-}"
DIAG_IFACE=${DIAG_IFACE:-""}
ROLLBACK_ID=${ROLLBACK_ID:-""}
BACKUP_DIR="${BACKUP_DIR:-${HOME}/.local/share/link-flap/backups}"
REPORT_DIR="${REPORT_DIR:-${HOME}/.local/share/link-flap/reports}"
EVENT_LOG="${EVENT_LOG:-${HOME}/.local/share/link-flap/events.log}"
_CONFIG_DIR="${XDG_CONFIG_HOME:-${HOME}/.config}/link-flap"
_CONFIG_FILE="${_CONFIG_DIR}/config"
_PROM_URL_FROM_FLAG=0        # set to 1 when -m is explicitly passed
_IPERF3_SERVER_FROM_FLAG=0   # set to 1 when -b is explicitly passed
_WEBHOOK_URL_FROM_FLAG=0     # set to 1 when -W is explicitly passed
_WINDOW_MINUTES_FROM_FLAG=0  # set to 1 when -w is explicitly passed
_FLAP_THRESHOLD_FROM_FLAG=0  # set to 1 when -t is explicitly passed
_NODE_EXPORTER_URL_FROM_FLAG=0 # set to 1 when -n is explicitly passed
_IPERF3_PORT_FROM_FLAG=0
_IPERF3_DURATION_FROM_FLAG=0
_IPERF3_PROTOCOL_FROM_FLAG=0
_IPERF3_BITRATE_FROM_FLAG=0
_IPERF3_SERVER_MODE=0
_CONFIG_ACTION=""             # --config show|reset
_FLAP_INTERACTIVE_MODE=0     # set to 1 when no-arg interactive menu ran
_INTERACTIVE_ARGS=()         # args to reconstruct for "re-run same test"
JSON_MODE=0                  # set to 1 when -j is passed
LOG_FILE=""                  # --log-file: append output to file
QUIET_MODE=0                 # --quiet: suppress all stdout
# shellcheck disable=SC2034  # FIX_MODE is read in lib/wizard.sh
FIX_MODE=0                   # --fix: auto-apply wizard fixes
FIX_DRY_RUN=0               # --fix-dry-run / --dry-run: preview fixes without applying
_SHOW_REPORTS=0              # --reports: list saved reports
REMOTE_HOST=""               # -H: run on remote machine via SSH
EXPORT_FILE=""               # --export: write Prometheus metrics to file

# ── Per-interface threshold overrides ────────────────────────────────────────
declare -A IFACE_THRESHOLDS=()       # e.g. IFACE_THRESHOLDS[eth0]=10

# ── JSON output accumulators ─────────────────────────────────────────────────
# Populated throughout the script when JSON_MODE=1; serialised at exit.
declare -a _JSON_IFACES=()           # JSON fragments per interface
_JSON_CORRELATION=""                 # "true" or ""
_JSON_LOG_SOURCE=""                  # journald, syslog, tshark, etc.
VERBOSE=0
SINCE_INPUT=""
UNTIL_INPUT=""
SINCE_EPOCH=""
UNTIL_EPOCH=""

# ── Colours (disabled when not a terminal) ────────────────────────────────────
if [[ -t 1 ]]; then
  RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'
  CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'
else
  RED=''; YELLOW=''; GREEN=''; CYAN=''; BOLD=''; DIM=''; RESET=''
fi

# ── Argument parsing ──────────────────────────────────────────────────────────
# Capture original args before any stripping so follow mode can re-exec intact.
_ORIG_ARGS=("$@")

# Pre-parse long options (getopts does not handle --foo).
FLEET_MODE=0
# shellcheck disable=SC2034  # DUT_IFACE is read in lib/wizard.sh
DUT_IFACE=""
_EVENTS_QUERY=""
_REBUILT_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --fleet)  FLEET_MODE=1 ;;
    --dut)
      # shellcheck disable=SC2034  # DUT_IFACE is read in lib/wizard.sh
      DUT_IFACE="${2:-}"; shift ;;
    --update) _do_update ;;
    --since)  SINCE_INPUT="${2:-}"; shift ;;
    --until)  UNTIL_INPUT="${2:-}"; shift ;;
    --events)   _EVENTS_QUERY="${2:-20}"; shift ;;
    --fix)
      # shellcheck disable=SC2034  # FIX_MODE is read in lib/wizard.sh
      FIX_MODE=1 ;;
    --fix-dry-run)
      # shellcheck disable=SC2034  # FIX_MODE/FIX_DRY_RUN read in lib/wizard.sh
      FIX_MODE=1; FIX_DRY_RUN=1 ;;
    --dry-run)
      # shellcheck disable=SC2034  # FIX_DRY_RUN read in lib/wizard.sh
      FIX_DRY_RUN=1 ;;
    --export)   EXPORT_FILE="${2:-}"; shift ;;
    --reports)  _SHOW_REPORTS=1 ;;
    --log-file) LOG_FILE="${2:-}"; shift ;;
    --version)  echo "$VERSION"; exit 0 ;;
    --quiet)    QUIET_MODE=1 ;;
    --config)   _CONFIG_ACTION="${2:-}"; shift ;;
    --iperf3-port)     IPERF3_PORT="${2:-}"; _IPERF3_PORT_FROM_FLAG=1; shift ;;
    --iperf3-duration) IPERF3_DURATION="${2:-}"; _IPERF3_DURATION_FROM_FLAG=1; shift ;;
    --iperf3-udp)      IPERF3_PROTOCOL="udp"; _IPERF3_PROTOCOL_FROM_FLAG=1 ;;
    --iperf3-bitrate)  IPERF3_BITRATE="${2:-}"; _IPERF3_BITRATE_FROM_FLAG=1; shift ;;
    --iperf3-server|--serve) _IPERF3_SERVER_MODE=1 ;;
    *)          _REBUILT_ARGS+=("$1") ;;
  esac
  shift
done
set -- "${_REBUILT_ARGS[@]+"${_REBUILT_ARGS[@]}"}"
while getopts ":w:t:i:p:m:n:b:d:r:f:W:H:jvh" opt; do
  case $opt in
    w) WINDOW_MINUTES="$OPTARG"; _WINDOW_MINUTES_FROM_FLAG=1 ;;
    t) # Parse per-interface thresholds (e.g. "eth0:10,eth1:5") or global integer
       if [[ "$OPTARG" == *:* ]]; then
         IFS=',' read -ra _tpairs <<< "$OPTARG"
         for _tp in "${_tpairs[@]}"; do
           _tp_iface="${_tp%%:*}"
           _tp_val="${_tp#*:}"
           if ! [[ "$_tp_val" =~ ^[0-9]+$ ]] || [[ "$_tp_val" -lt 2 ]]; then
             echo "Error: -t per-interface threshold for '${_tp_iface}' must be >= 2." >&2; exit 2
           fi
           IFACE_THRESHOLDS["$_tp_iface"]="$_tp_val"
         done
       else
         FLAP_THRESHOLD="$OPTARG"
       fi
       _FLAP_THRESHOLD_FROM_FLAG=1 ;;
    i) IFACE_FILTER="$OPTARG"   ;;
    p) PCAP_FILE="$OPTARG"      ;;
    m) PROM_URL="$OPTARG";       _PROM_URL_FROM_FLAG=1     ;;
    n) NODE_EXPORTER_URL="$OPTARG"; _NODE_EXPORTER_URL_FROM_FLAG=1 ;;
    b) IPERF3_SERVER="$OPTARG";  _IPERF3_SERVER_FROM_FLAG=1 ;;
    d) DIAG_IFACE="$OPTARG"     ;;
    r) ROLLBACK_ID="$OPTARG"    ;;
    f) FOLLOW_SECONDS="$OPTARG" ;;
    j) JSON_MODE=1              ;;
    W) WEBHOOK_URL="$OPTARG"; _WEBHOOK_URL_FROM_FLAG=1 ;;
    H) REMOTE_HOST="$OPTARG"   ;;
    v) VERBOSE=1                ;;
    h) usage                    ;;
    :) echo "Option -$OPTARG requires an argument." >&2; exit 2 ;;
    \?) echo "Unknown option: -$OPTARG" >&2; exit 2 ;;
  esac
done

# ── SSH remote execution (-H user@host) ─────────────────────────────────────
if [[ -n "$REMOTE_HOST" ]]; then
  # Validate host format (user@host or bare host/IP)
  if [[ ! "$REMOTE_HOST" =~ ^[a-zA-Z0-9._@-]+$ ]]; then
    echo "Error: -H: invalid host format '${REMOTE_HOST}'." >&2; exit 2
  fi
  if ! command -v ssh >/dev/null 2>&1; then
    echo "Error: -H requires ssh but it is not installed." >&2; exit 2
  fi
  # Build remote args: everything except -H
  _remote_args=()
  for _ra in "${_ORIG_ARGS[@]}"; do
    [[ "$_ra" == "-H" ]] && continue
    [[ "$_ra" == "$REMOTE_HOST" ]] && continue
    _remote_args+=("$_ra")
  done
  _remote_tmp=$(ssh -o ConnectTimeout=10 -o BatchMode=yes "$REMOTE_HOST" \
    "mktemp /tmp/flap-remote-XXXXXX") || {
    echo "Error: -H: failed to connect to ${REMOTE_HOST}." >&2; exit 2
  }
  timeout 30 scp -o ConnectTimeout=10 -q "$0" "${REMOTE_HOST}:${_remote_tmp}" || {
    echo "Error: -H: failed to copy script to ${REMOTE_HOST}." >&2; exit 2
  }
  # shellcheck disable=SC2029
  _remote_args_escaped=""
  [[ ${#_remote_args[@]} -gt 0 ]] && _remote_args_escaped=$(printf '%q ' "${_remote_args[@]}")
  timeout 300 ssh -o ConnectTimeout=10 -o BatchMode=yes "$REMOTE_HOST" \
    "bash '${_remote_tmp}' ${_remote_args_escaped}; _rc=\$?; rm -f '${_remote_tmp}'; exit \$_rc"
  exit $?
fi

# When wizard mode is active, pre-filter events to the target interface
[[ -n "$DIAG_IFACE" && -z "$IFACE_FILTER" ]] && IFACE_FILTER="$DIAG_IFACE"

# ── Load + prompt for server config ──────────────────────────────────────────
_load_config

# ── Config action (--config show|reset) ──────────────────────────────────────
if [[ -n "$_CONFIG_ACTION" ]]; then
  case "$_CONFIG_ACTION" in
    show)
      echo "Config file: ${_CONFIG_FILE}"
      if [[ -f "$_CONFIG_FILE" ]]; then
        echo ""
        while IFS='=' read -r _ck _cv; do
          [[ -z "$_ck" || "$_ck" == \#* ]] && continue
          printf '  %-22s  %s\n' "$_ck" "$_cv"
        done < "$_CONFIG_FILE"
      else
        echo "  (no saved config)"
      fi
      exit 0
      ;;
    reset)
      if [[ -f "$_CONFIG_FILE" ]]; then
        rm -f "$_CONFIG_FILE"
        echo "Config cleared: ${_CONFIG_FILE}"
      else
        echo "No config file to clear."
      fi
      exit 0
      ;;
    *)
      echo "Error: --config accepts 'show' or 'reset', got '${_CONFIG_ACTION}'." >&2
      exit 2
      ;;
  esac
fi

# ── Server mode (--iperf3-server) ───────────────────────────────────────────
if [[ "$_IPERF3_SERVER_MODE" -eq 1 ]]; then
  if [[ -z "${_LINK_FLAP_TEST_IPERF3:-}" ]] && ! command -v iperf3 &>/dev/null; then
    echo "Error: --iperf3-server requires iperf3." >&2; exit 2
  fi
  # Test mode: print config and exit (no exec)
  if [[ -n "${_LINK_FLAP_TEST_IPERF3:-}" ]]; then
    echo "iperf3 server mode: port=$IPERF3_PORT"
    exit 0
  fi
  echo -e "${BOLD}Starting iperf3 server${RESET} on port ${IPERF3_PORT}"
  echo "Protocol: ${IPERF3_PROTOCOL:-tcp}  |  Press Ctrl-C to stop"
  echo ""
  exec iperf3 -s -p "$IPERF3_PORT" --json
fi

# Persist values that were explicitly passed as flags
[[ "$_PROM_URL_FROM_FLAG"      -eq 1 ]] && _save_config "PROM_URL"      "$PROM_URL"
[[ "$_IPERF3_SERVER_FROM_FLAG" -eq 1 ]] && _save_config "IPERF3_SERVER" "$IPERF3_SERVER"
[[ "$_WEBHOOK_URL_FROM_FLAG"   -eq 1 ]] && _save_config "WEBHOOK_URL"   "$WEBHOOK_URL"
[[ "$_WINDOW_MINUTES_FROM_FLAG" -eq 1 ]] && _save_config "WINDOW_MINUTES" "$WINDOW_MINUTES"
[[ "$_FLAP_THRESHOLD_FROM_FLAG" -eq 1 ]] && _save_config "FLAP_THRESHOLD" "$FLAP_THRESHOLD"
[[ "$_NODE_EXPORTER_URL_FROM_FLAG" -eq 1 ]] && _save_config "NODE_EXPORTER_URL" "$NODE_EXPORTER_URL"
[[ "$_IPERF3_PORT_FROM_FLAG"     -eq 1 ]] && _save_config "IPERF3_PORT"     "$IPERF3_PORT"
[[ "$_IPERF3_DURATION_FROM_FLAG" -eq 1 ]] && _save_config "IPERF3_DURATION" "$IPERF3_DURATION"
[[ "$_IPERF3_PROTOCOL_FROM_FLAG" -eq 1 ]] && _save_config "IPERF3_PROTOCOL" "$IPERF3_PROTOCOL"
[[ "$_IPERF3_BITRATE_FROM_FLAG"  -eq 1 ]] && _save_config "IPERF3_BITRATE"  "$IPERF3_BITRATE"

# Interactive prompts (all self-guard for TTY / test mode)
_prompt_prom_url

# ── Validate numerics ─────────────────────────────────────────────────────────
if ! [[ "$WINDOW_MINUTES" =~ ^[0-9]+$ ]] || \
   [[ "$WINDOW_MINUTES" -lt 1 ]] || [[ "$WINDOW_MINUTES" -gt 43200 ]]; then
  echo "Error: -w must be between 1 and 43200 (minutes)." >&2; exit 2
fi
if [[ "$WINDOW_MINUTES" -gt 1440 ]]; then
  echo "Warning: -w ${WINDOW_MINUTES} (>24h) — scanning may be slow on large log files." >&2
fi
if ! [[ "$FLAP_THRESHOLD" =~ ^[0-9]+$ ]] || [[ "$FLAP_THRESHOLD" -lt 2 ]]; then
  echo "Error: -t must be >= 2." >&2; exit 2
fi
if [[ -n "$PCAP_FILE" ]] && [[ ! -r "$PCAP_FILE" ]]; then
  echo "Error: -p: cannot read file '$PCAP_FILE'." >&2; exit 2
fi
if [[ -n "$PROM_URL" ]] && ! command -v curl &>/dev/null; then
  echo "Error: -m requires curl (not found)." >&2; exit 2
fi
if [[ -n "$IPERF3_SERVER" ]] && [[ -z "${_LINK_FLAP_TEST_IPERF3:-}" ]] && \
   ! command -v iperf3 &>/dev/null; then
  echo "Error: -b requires iperf3 (not found). Install with: apt install iperf3" >&2; exit 2
fi
if ! [[ "$IPERF3_PORT" =~ ^[0-9]+$ ]] || [[ "$IPERF3_PORT" -lt 1 ]] || [[ "$IPERF3_PORT" -gt 65535 ]]; then
  echo "Error: --iperf3-port must be an integer between 1 and 65535." >&2; exit 2
fi
if ! [[ "$IPERF3_DURATION" =~ ^[0-9]+$ ]] || [[ "$IPERF3_DURATION" -lt 1 ]] || [[ "$IPERF3_DURATION" -gt 3600 ]]; then
  echo "Error: --iperf3-duration must be an integer between 1 and 3600." >&2; exit 2
fi
if [[ -n "$IPERF3_PROTOCOL" ]] && [[ "$IPERF3_PROTOCOL" != "tcp" ]] && [[ "$IPERF3_PROTOCOL" != "udp" ]]; then
  echo "Error: --iperf3-udp protocol must be empty, 'tcp', or 'udp'." >&2; exit 2
fi
if [[ -n "$IPERF3_BITRATE" ]] && ! [[ "$IPERF3_BITRATE" =~ ^[0-9]+(\.[0-9]+)?[KMGkmg]?$ ]]; then
  echo "Error: --iperf3-bitrate must be a number with optional K/M/G suffix (e.g. 100M)." >&2; exit 2
fi
if [[ -n "$FOLLOW_SECONDS" ]] && \
   { ! [[ "$FOLLOW_SECONDS" =~ ^[0-9]+$ ]] || [[ "$FOLLOW_SECONDS" -lt 1 ]]; }; then
  echo "Error: -f must be a positive integer (seconds)." >&2; exit 2
fi
if [[ -n "$NODE_EXPORTER_URL" ]] && \
   [[ "$NODE_EXPORTER_URL" != "off" ]] && \
   ! [[ "$NODE_EXPORTER_URL" =~ ^https?:// ]]; then
  echo "Error: -n must be 'off' or a URL starting with http:// or https://" >&2; exit 2
fi
if [[ -n "$WEBHOOK_URL" ]] && ! [[ "$WEBHOOK_URL" =~ ^https?:// ]]; then
  echo "Error: -W must be a URL starting with http:// or https://" >&2; exit 2
fi
if [[ "$FLEET_MODE" -eq 1 ]] && [[ -z "$PROM_URL" ]]; then
  echo "Error: --fleet requires -m URL (Prometheus base URL)." >&2; exit 2
fi
if [[ -n "$SINCE_INPUT" ]]; then
  SINCE_EPOCH=$(_to_epoch "$SINCE_INPUT" "00:00:00")
  [[ -z "$SINCE_EPOCH" ]] && \
    echo "Error: --since: cannot parse '$SINCE_INPUT' (use YYYY-MM-DD or 'YYYY-MM-DD HH:MM:SS')." >&2 && exit 2
fi
if [[ -n "$UNTIL_INPUT" ]]; then
  UNTIL_EPOCH=$(_to_epoch "$UNTIL_INPUT" "23:59:59")
  [[ -z "$UNTIL_EPOCH" ]] && \
    echo "Error: --until: cannot parse '$UNTIL_INPUT' (use YYYY-MM-DD or 'YYYY-MM-DD HH:MM:SS')." >&2 && exit 2
fi
if [[ -n "$SINCE_EPOCH" && -n "$UNTIL_EPOCH" ]] && [[ "$UNTIL_EPOCH" -le "$SINCE_EPOCH" ]]; then
  echo "Error: --until must be after --since." >&2; exit 2
fi
if [[ "$FLEET_MODE" -eq 1 && -n "$SINCE_EPOCH" ]]; then
  echo "Error: --since/--until are not supported with --fleet." >&2; exit 2
fi

# ── Output redirection (--log-file, --quiet) ─────────────────────────────────
if [[ -n "$LOG_FILE" ]]; then
  exec >> "$LOG_FILE"
  # ANSI is already disabled when stdout is not a terminal ([[ -t 1 ]] failed)
fi
if [[ "$QUIET_MODE" -eq 1 && -z "$LOG_FILE" ]]; then
  exec 1>/dev/null
fi

# ── Update check (skipped in non-interactive, follow children, rollback) ──────
_check_for_update
_interactive_menu      # no-op unless no-args + TTY + not test mode

# ── Event log query (--events) ───────────────────────────────────────────────
if [[ -n "$_EVENTS_QUERY" ]]; then
  if [[ ! -f "$EVENT_LOG" ]]; then
    echo "No event log found at ${EVENT_LOG}."
    exit 0
  fi
  if [[ "$_EVENTS_QUERY" == "all" ]]; then
    cat "$EVENT_LOG"
  elif [[ "$_EVENTS_QUERY" =~ ^[0-9]+$ ]]; then
    tail -n "$_EVENTS_QUERY" "$EVENT_LOG"
  else
    # Treat as a date prefix filter (e.g. "2026-03-01")
    awk -F'\t' -v q="$_EVENTS_QUERY" 'substr($0,1,length(q))==q' "$EVENT_LOG" || echo "No events matching '${_EVENTS_QUERY}'."
  fi
  exit 0
fi

# ── Report aggregation (--reports) ───────────────────────────────────────────
if [[ "$_SHOW_REPORTS" -eq 1 ]]; then
  shopt -s nullglob
  _report_files=("${REPORT_DIR}"/*.txt)
  shopt -u nullglob
  if [[ ${#_report_files[@]} -eq 0 ]]; then
    echo "No saved reports in ${REPORT_DIR}."
    exit 0
  fi
  printf "%-24s  %-12s  %s  %s\n" "Date" "Interface" "Causes" "Warnings"
  printf "%-24s  %-12s  %s  %s\n" "────────────────────────" "────────────" "──────" "────────"
  for _rf in "${_report_files[@]}"; do
    _fname=$(basename "$_rf" .txt)
    # backup_id format: YYYYMMDD-HHMMSS-iface
    _date="${_fname:0:8}"
    _time="${_fname:9:6}"
    _iface="${_fname:16}"
    _pretty_date="${_date:0:4}-${_date:4:2}-${_date:6:2} ${_time:0:2}:${_time:2:2}:${_time:4:2}"
    _causes=$(grep -c '^\[CAUSE\]\|^  \[.*\] \[CAUSE\]' "$_rf" 2>/dev/null || echo "0")
    _warns=$(grep -c '^\[WARN\]\|^  \[.*\] \[WARN\]' "$_rf" 2>/dev/null || echo "0")
    printf "%-24s  %-12s  %-6s  %s\n" "$_pretty_date" "$_iface" "$_causes" "$_warns"
  done
  echo ""
  echo "${#_report_files[@]} report(s) in ${REPORT_DIR}"
  exit 0
fi

# ── Temp file — cleaned up on exit ───────────────────────────────────────────
TMPFILE=$(mktemp /tmp/link-flap-XXXXXX) || {
  echo "Error: failed to create temp file." >&2; exit 2
}
# _SHUTTING_DOWN, _graceful_shutdown, and trap are defined in lib/signals.sh.
# If running without lib/ (standalone bundle), provide a minimal fallback.
if [[ "$(type -t _graceful_shutdown)" != "function" ]]; then
  _SHUTTING_DOWN=0
  _graceful_shutdown() { _SHUTTING_DOWN=1; rm -f "$TMPFILE"; }
  trap '_graceful_shutdown' EXIT INT TERM HUP
fi

if [[ -n "$ROLLBACK_ID" ]]; then do_rollback "$ROLLBACK_ID"; exit 0; fi


# ── Step 1: Collect raw log lines ─────────────────────────────────────────────
# Format we aim to emit into TMPFILE for each event:
#   <epoch_seconds> <iface> <UP|DOWN>
#
# We try journald first (Ubuntu 24.04 default). Fall back to flat log files.

# shellcheck disable=SC2034  # SINCE_ARG is read in lib/log-collection.sh
SINCE_ARG="${WINDOW_MINUTES} minutes ago"

# ── Step 2: Populate TMPFILE ──────────────────────────────────────────────────
LOG_SOURCE="journald"

if [[ "$FLEET_MODE" -eq 0 ]]; then
  if [[ -n "${_LINK_FLAP_TEST_INPUT:-}" ]]; then
    # Test hook: bypass journald/syslog and read from a supplied file.
    # Set by the test suite only — not a documented end-user option.
    LOG_SOURCE="test-input"
    collect_from_syslog "$_LINK_FLAP_TEST_INPUT" | parse_events >> "$TMPFILE"
  elif [[ -n "${_LINK_FLAP_TEST_TSHARK:-}" ]]; then
    LOG_SOURCE="test-tshark"
    if [[ -n "$IFACE_FILTER" ]]; then
      awk -v f="$IFACE_FILTER" '$2 == f' "$_LINK_FLAP_TEST_TSHARK" >> "$TMPFILE"
    else
      cat "$_LINK_FLAP_TEST_TSHARK" >> "$TMPFILE"
    fi
  elif [[ -n "$PCAP_FILE" ]]; then
    LOG_SOURCE="tshark ($PCAP_FILE)"
    collect_from_tshark "$PCAP_FILE" >> "$TMPFILE"
  elif command -v journalctl &>/dev/null; then
    collect_from_journald | parse_events >> "$TMPFILE"
  else
    LOG_SOURCE="syslog files"
    for f in /var/log/syslog /var/log/kern.log /var/log/messages; do
      collect_from_syslog "$f" | parse_events >> "$TMPFILE"
    done
  fi

  # Remove duplicate lines (same epoch + iface + state from multiple sources)
  sort -u "$TMPFILE" -o "$TMPFILE"

  # Apply --since / --until epoch filter when a date range is specified
  if [[ -n "$SINCE_EPOCH" || -n "$UNTIL_EPOCH" ]]; then
    _RANGE_NOW=$(date +%s)
    awk -v s="${SINCE_EPOCH:-0}" -v u="${UNTIL_EPOCH:-$_RANGE_NOW}" \
      '$1+0 >= s+0 && $1+0 <= u+0' "$TMPFILE" > "${TMPFILE}.range"
    mv "${TMPFILE}.range" "$TMPFILE"
  fi
fi

# ── Step 3: Analyse for flapping ─────────────────────────────────────────────
# For each interface: count state transitions, report if >= FLAP_THRESHOLD

# Probe node_exporter once; result cached for wizard and per-interface blocks below
fetch_node_exporter || true
# In wizard mode: auto-detect local bind IP and remote peer IP for iperf3.
# No user prompt needed — both ends are resolved from the interface.
if [[ -n "$DIAG_IFACE" ]]; then
  # Local bind IP: IPv4 preferred, fall back to global/ULA IPv6 (skip link-local)
  _iface_addr_raw=$(ip addr show "$DIAG_IFACE" 2>/dev/null || true)
  _iperf3_local_ip=$(echo "$_iface_addr_raw" \
    | grep -oP 'inet \K[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' | head -1 || true)
  if [[ -z "$_iperf3_local_ip" ]]; then
    _iperf3_local_ip=$(echo "$_iface_addr_raw" \
      | grep 'inet6' | grep -v 'scope link' \
      | grep -oP 'inet6 \K[0-9a-f:]+' | head -1 || true)
  fi

  # Remote peer IP (only auto-set if not already configured via -b or config)
  if [[ -z "$IPERF3_SERVER" ]]; then
    # Try LLDP management IP first (most accurate — IP of the directly connected device)
    if command -v lldpctl &>/dev/null; then
      _lldp_peer_raw=$(timeout 5 lldpctl "$DIAG_IFACE" 2>/dev/null || true)
      IPERF3_SERVER=$(echo "$_lldp_peer_raw" \
        | grep -oP '(?i)mgmtip:\s*\K[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' | head -1 || true)
    fi
    # Fall back to default gateway (next-hop router on this interface)
    if [[ -z "$IPERF3_SERVER" ]]; then
      IPERF3_SERVER=$(ip route show dev "$DIAG_IFACE" 2>/dev/null \
        | awk '/^default/{print $3; exit}' || true)
    fi
  fi

  run_iperf3 "$DIAG_IFACE" "$_iperf3_local_ip" || true
else
  run_iperf3 || true
fi

if [[ -n "$DIAG_IFACE" ]]; then
  run_wizard "$DIAG_IFACE"
  _flap_what_next 0
  exit 0
fi

FLAPPING_FOUND=0
FLAPPING_COUNT=0
FLAPPING_IFACES=()
declare -A FLAPPING_TRANSITIONS=()

# ── Follow-mode deduplication state ──────────────────────────────────────────
# Parse previous-cycle state for alert deduplication. _FLAP_PREV_FLAPPING is a
# space-delimited list of interfaces that were flapping last cycle (already
# exists). _FLAP_PREV_TRANSITIONS is comma-delimited iface=count pairs carrying
# the transition counts from the previous cycle.
declare -A _prev_flapping_set=()
declare -A _prev_transition_counts=()
for _pi in ${_FLAP_PREV_FLAPPING:-}; do
  _prev_flapping_set["$_pi"]=1
done
IFS=',' read -ra _pt_pairs <<< "${_FLAP_PREV_TRANSITIONS:-}"
for _ptp in "${_pt_pairs[@]}"; do
  [[ "$_ptp" == *=* ]] || continue
  _pt_iface="${_ptp%%=*}"
  _pt_count="${_ptp#*=}"
  _prev_transition_counts["$_pt_iface"]="$_pt_count"
done

# Get unique interfaces from TMPFILE
mapfile -t IFACES < <(awk '{print $2}' "$TMPFILE" | sort -u)

# ── JSON mode: suppress human-readable output ───────────────────────────────
# Save real stdout to fd 3 and redirect all subsequent echo/printf to /dev/null.
# Structured data is collected into _JSON_* accumulators and emitted at exit.
if [[ "$JSON_MODE" -eq 1 ]]; then
  exec 3>&1
  exec 1>/dev/null
fi
_JSON_LOG_SOURCE="$LOG_SOURCE"

# ── Test-mode warning ─────────────────────────────────────────────────────────
# Print an unmissable banner whenever any synthetic data hook is active, so
# there is zero ambiguity between a test run and a real system scan.
_TEST_ACTIVE=0
[[ -n "${_LINK_FLAP_TEST_INPUT:-}"         ]] && _TEST_ACTIVE=1
[[ -n "${_LINK_FLAP_TEST_TSHARK:-}"        ]] && _TEST_ACTIVE=1
[[ -n "${_LINK_FLAP_TEST_PROM:-}"          ]] && _TEST_ACTIVE=1
[[ -n "${_LINK_FLAP_TEST_NODE_EXPORTER:-}" ]] && _TEST_ACTIVE=1
[[ -n "${_LINK_FLAP_TEST_IPERF3:-}"        ]] && _TEST_ACTIVE=1
[[ -n "${_LINK_FLAP_TEST_WIZARD_DIR:-}"    ]] && _TEST_ACTIVE=1
[[ -n "${_LINK_FLAP_TEST_PROM_ALL:-}"      ]] && _TEST_ACTIVE=1

if [[ $_TEST_ACTIVE -eq 1 ]]; then
  echo ""
  echo -e "${YELLOW}${BOLD}╔══════════════════════════════════════════════════════╗${RESET}"
  echo -e "${YELLOW}${BOLD}║  WARNING: SYNTHETIC TEST DATA — NOT REAL SYSTEM DATA ║${RESET}"
  echo -e "${YELLOW}${BOLD}╚══════════════════════════════════════════════════════╝${RESET}"
  [[ -n "${_LINK_FLAP_TEST_INPUT:-}"         ]] && echo -e "${YELLOW}  Logs    : synthetic file (not journald/syslog)${RESET}"
  [[ -n "${_LINK_FLAP_TEST_TSHARK:-}"        ]] && echo -e "${YELLOW}  tshark  : synthetic packet data (not a real pcap)${RESET}"
  [[ -n "${_LINK_FLAP_TEST_PROM:-}"          ]] && echo -e "${YELLOW}  Prom    : canned API response (not a real Prometheus)${RESET}"
  [[ -n "${_LINK_FLAP_TEST_NODE_EXPORTER:-}" ]] && echo -e "${YELLOW}  NE      : canned metrics (not a real node_exporter)${RESET}"
  [[ -n "${_LINK_FLAP_TEST_IPERF3:-}"        ]] && echo -e "${YELLOW}  iperf3  : canned JSON (not a real iperf3 run)${RESET}"
  [[ -n "${_LINK_FLAP_TEST_WIZARD_DIR:-}"    ]] && echo -e "${YELLOW}  Wizard  : mocked sysfs/ethtool (not real hardware)${RESET}"
  [[ -n "${_LINK_FLAP_TEST_PROM_ALL:-}"      ]] && echo -e "${YELLOW}  Fleet   : canned Prom multi-result (not a real Prometheus)${RESET}"
fi

echo ""
if [[ "$FLEET_MODE" -eq 1 ]]; then
  echo -e "${BOLD}Link Flap Detector${RESET} — ${BOLD}fleet mode${RESET}"
else
  echo -e "${BOLD}Link Flap Detector${RESET} — source: ${LOG_SOURCE}"
fi
if [[ -n "$SINCE_EPOCH" ]]; then
  _since_disp=$(date -d "@$SINCE_EPOCH" "+%Y-%m-%d %H:%M:%S")
  _until_disp=$(date -d "@${UNTIL_EPOCH:-$(date +%s)}" "+%Y-%m-%d %H:%M:%S")
  echo -e "Window: ${_since_disp} → ${_until_disp}  |  Flap threshold: ${FLAP_THRESHOLD} transitions"
else
  echo -e "Window: last ${WINDOW_MINUTES}m  |  Flap threshold: ${FLAP_THRESHOLD} transitions"
fi
[[ -n "$IFACE_FILTER" ]] && echo -e "Interface filter: ${CYAN}${IFACE_FILTER}${RESET}"
[[ -n "$PROM_URL" ]] && echo -e "Prometheus: ${CYAN}${PROM_URL}${RESET}"
[[ -n "$_NE_METRICS_CACHE" ]] && echo -e "node_exporter: ${CYAN}${NODE_EXPORTER_URL}${RESET}"
[[ -n "$_IPERF3_RESULT_CACHE" ]] && echo -e "iperf3: ${CYAN}${IPERF3_SERVER}${RESET}"
[[ -n "$FOLLOW_SECONDS" ]] && echo -e "Follow: every ${CYAN}${FOLLOW_SECONDS}s${RESET}  (Ctrl-C to stop)"
[[ -n "$WEBHOOK_URL" ]] && echo -e "Webhook: ${CYAN}${WEBHOOK_URL}${RESET}"
echo ""

# Fleet mode: query Prometheus directly — bypass per-interface local-log analysis
if [[ "$FLEET_MODE" -eq 1 ]]; then
  _fleet_rc=0
  fleet_scan_prometheus || _fleet_rc=$?
  [[ "$_fleet_rc" -eq 2 ]] && exit 2
  exit $(( FLAPPING_FOUND ))
fi

if [[ ${#IFACES[@]} -eq 0 ]]; then
  echo -e "${GREEN}No link state events found in the log window.${RESET}"
  echo ""
  if [[ -n "$FOLLOW_SECONDS" ]]; then
    # Print [CLEARED] and fire webhook for any ifaces that were flapping last cycle
    for _pi in ${_FLAP_PREV_FLAPPING:-}; do
      echo -e "${GREEN}${BOLD}[CLEARED]${RESET} ${BOLD}${_pi}${RESET} — link has stabilised"
      echo ""
      [[ -n "$WEBHOOK_URL" ]] && _send_webhook "$WEBHOOK_URL" "cleared" "$_pi"
    done
    echo -e "${DIM}--- next scan in ${FOLLOW_SECONDS}s (Ctrl-C to stop) ---${RESET}"
    sleep "$FOLLOW_SECONDS"
    exec env _FLAP_FOLLOW_CHILD=1 _FLAP_PREV_FLAPPING="" _FLAP_PREV_TRANSITIONS="" "$0" "${_ORIG_ARGS[@]}"
  fi
  if [[ "$JSON_MODE" -eq 1 ]]; then
    exec 1>&3
    _emit_json "" "false" "false" "0" ""
  fi
  exit 0
fi

for iface in "${IFACES[@]}"; do
  # Per-interface grep on TMPFILE: kept for clarity over a single-pass approach.
  # TMPFILE is small (hundreds of lines max) and interface count is typically <10,
  # so the O(n*m) cost is negligible versus the readability benefit.
  mapfile -t EVENTS < <(grep -F -- " $iface " "$TMPFILE" | sort -n)

  count=${#EVENTS[@]}
  [[ "$count" -lt 2 ]] && continue   # Need at least 2 events to detect flapping

  # Count transitions (state changes between consecutive events)
  transitions=0
  prev_state=""
  declare -a event_lines=()

  for evt in "${EVENTS[@]}"; do
    IFS=' ' read -r epoch _evt_iface state <<< "$evt"
    ts_human=$(date -d "@$epoch" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "unknown")

    _sc="$RED"; [[ "$state" == "UP" ]] && _sc="$GREEN"
    event_lines+=("  ${DIM}${ts_human}${RESET}  ${_sc}${state}${RESET}")

    if [[ -n "$prev_state" && "$state" != "$prev_state" ]]; then
      (( transitions++ )) || true
    fi
    prev_state="$state"
  done

  # First and last event timestamps
  first_epoch=$(echo "${EVENTS[0]}"  | awk '{print $1}')
  last_epoch=$(echo  "${EVENTS[-1]}" | awk '{print $1}')
  first_ts=$(date -d "@$first_epoch" "+%H:%M:%S" 2>/dev/null || echo "?")
  last_ts=$(date -d  "@$last_epoch"  "+%H:%M:%S" 2>/dev/null || echo "?")
  span=$(( last_epoch - first_epoch ))
  span_str="${span}s"
  [[ "$span" -ge 60 ]] && span_str="$(( span / 60 ))m $(( span % 60 ))s"

  # ── JSON: collect per-interface data ─────────────────────────────────────
  if [[ "$JSON_MODE" -eq 1 ]]; then
    _j_status="active"
    _iface_thresh="${IFACE_THRESHOLDS[$iface]:-$FLAP_THRESHOLD}"
    [[ "$transitions" -ge "$_iface_thresh" ]] && _j_status="flapping"
    _j_events=""
    for evt in "${EVENTS[@]}"; do
      IFS=' ' read -r _je _ji _js <<< "$evt"
      _je_iso=$(date -d "@$_je" -u "+%Y-%m-%dT%H:%M:%S+0000" 2>/dev/null || echo "unknown")
      [[ -n "$_j_events" ]] && _j_events+=","
      _j_events+="{\"epoch\":${_je},\"timestamp\":\"${_je_iso}\",\"state\":\"${_js}\"}"
    done
    _j_first_iso=$(date -d "@$first_epoch" -u "+%Y-%m-%dT%H:%M:%S+0000" 2>/dev/null || echo "unknown")
    _j_last_iso=$(date -d "@$last_epoch" -u "+%Y-%m-%dT%H:%M:%S+0000" 2>/dev/null || echo "unknown")
    # Recurring check for JSON: count past FLAPPING entries in event log
    _j_recurring="false"
    if [[ -f "$EVENT_LOG" ]]; then
      _j_past=$(awk -F'\t' -v iface="$iface" '$2 == iface && $3 == "FLAPPING" { c++ } END { print c+0 }' "$EVENT_LOG" 2>/dev/null || echo "0")
      [[ "$_j_past" -ge 3 ]] && _j_recurring="true"
    fi
    _JSON_IFACES+=("{\"name\":\"${iface}\",\"status\":\"${_j_status}\",\"transitions\":${transitions},\"event_count\":${count},\"first_event\":\"${_j_first_iso}\",\"last_event\":\"${_j_last_iso}\",\"span_seconds\":${span},\"recurring\":${_j_recurring},\"events\":[${_j_events}]}")
  fi

  _iface_thresh="${IFACE_THRESHOLDS[$iface]:-$FLAP_THRESHOLD}"
  if [[ "$transitions" -ge "$_iface_thresh" ]]; then
    FLAPPING_FOUND=1
    (( FLAPPING_COUNT++ )) || true
    FLAPPING_IFACES+=("$iface")
    FLAPPING_TRANSITIONS["$iface"]=$transitions
    _bond_label=""
    _bond_m=$(_get_bond_master "$iface")
    [[ -n "$_bond_m" ]] && _bond_label="  ${DIM}(bond member of ${_bond_m})${RESET}"

    # Follow-mode dedup: if this interface was already flapping last cycle,
    # print a compact one-liner instead of the full enrichment block.
    if [[ -n "${_prev_flapping_set[$iface]:-}" && -n "$FOLLOW_SECONDS" ]]; then
      _prev_t="${_prev_transition_counts[$iface]:-?}"
      echo -e "${YELLOW}${BOLD}[STILL FLAPPING]${RESET} ${BOLD}${iface}${RESET}${_bond_label} — ${transitions} transitions (was ${_prev_t})"
      echo ""
    else
      echo -e "${RED}${BOLD}[FLAPPING]${RESET} ${BOLD}${iface}${RESET}${_bond_label}"
      echo -e "  Transitions : ${RED}${transitions}${RESET}  |  Events: ${count}  |  Span: ${first_ts}–${last_ts} (${span_str})"
      if [[ "$VERBOSE" -eq 1 ]]; then
        for el in "${event_lines[@]}"; do
          echo -e "$el"
        done
      fi
      show_prometheus_context "$iface"
      show_system_load_at_flap "$iface" "$first_epoch"
      show_node_exporter_context "$iface"
      show_iperf3_context "$iface"
      echo ""
    fi
  else
    if [[ "$VERBOSE" -eq 1 ]]; then
      echo -e "${YELLOW}${BOLD}[ACTIVE]${RESET}  ${BOLD}${iface}${RESET} — ${transitions} transition(s) in window (below threshold)"
      for el in "${event_lines[@]}"; do
        echo -e "$el"
      done
      show_prometheus_context "$iface"
      show_system_load_at_flap "$iface" "$first_epoch"
      show_node_exporter_context "$iface"
      show_iperf3_context "$iface"
      echo ""
    fi
  fi
done

# Warn if Prometheus was configured but returned no data.
# _PROM_REACHABLE is set by prom_query/prom_query_at on successful curl;
# _PROM_REACHED is set by show_prometheus_context when data was found.
if [[ -n "$PROM_URL" ]] && [[ "$_PROM_REACHED" -eq 0 ]]; then
  if [[ "$_PROM_REACHABLE" -eq 1 ]]; then
    echo -e "${DIM}(Prometheus connected but no network metrics found for this interface — check that node_exporter is running and exposing /sys/class/net metrics)${RESET}"
  else
    echo -e "${DIM}(Prometheus at ${PROM_URL} is unreachable — verify connectivity)${RESET}"
  fi
  echo ""
fi
# Warn if Prometheus queries timed out (curl failures counted in lib/prometheus.sh)
if [[ -n "$PROM_URL" ]] && [[ "${_PROM_QUERY_FAILURES:-0}" -gt 0 ]]; then
  echo -e "${DIM}(${_PROM_QUERY_FAILURES} Prometheus query/queries timed out — enrichment data may be incomplete)${RESET}"
  echo ""
fi

# ── Follow-mode: report cleared interfaces ───────────────────────────────────
# In follow mode, any interface that was flapping last cycle but is NOT in the
# current FLAPPING_IFACES list has cleared.
if [[ -n "$FOLLOW_SECONDS" ]] && [[ ${#_prev_flapping_set[@]} -gt 0 ]]; then
  declare -A _curr_flapping_set_dedup=()
  for _wi in "${FLAPPING_IFACES[@]}"; do _curr_flapping_set_dedup["$_wi"]=1; done
  for _pi in "${!_prev_flapping_set[@]}"; do
    if [[ -z "${_curr_flapping_set_dedup[$_pi]:-}" ]]; then
      echo -e "${GREEN}${BOLD}[CLEARED]${RESET} ${BOLD}${_pi}${RESET} — link has stabilised"
      echo ""
    fi
  done
fi

# ── Cross-interface correlation ────────────────────────────────────────────────
# If 2+ interfaces are flapping, check whether any of their events fell in the
# same 10-second bucket — a strong hint of a common upstream cause.
# 10s window balances STP fast-forward (2s) through LACP slow timeout (90s);
# wide enough to catch related events, narrow enough to avoid false correlation.
if [[ "$FLAPPING_COUNT" -ge 2 ]]; then
  _corr=$(awk '
  {
    bucket = int($1 / 10) * 10
    key    = bucket SUBSEP $2
    if (!(key in seen)) {
      seen[key] = 1
      count[bucket]++
      if (count[bucket] >= 2) { print "yes"; exit }
    }
  }
  ' "$TMPFILE")
  if [[ "$_corr" == "yes" ]]; then
    _JSON_CORRELATION="true"
    echo -e "  ${YELLOW}[CORRELATED]${RESET} Multiple interfaces had events in the same 10-second window."
    echo -e "  ${DIM}Possible shared cause: switch reboot, upstream link failure, power event, or broadcast storm.${RESET}"
    echo ""
  fi
fi

# ── Recurring-issue detection ──────────────────────────────────────────────────
# For each flapping interface, check the persistent event log for past FLAPPING
# entries. If >= 3 past occurrences, flag as [RECURRING].
declare -A _RECURRING_IFACES=()
if [[ -f "$EVENT_LOG" ]] && [[ ${#FLAPPING_IFACES[@]} -gt 0 ]]; then
  for _ri in "${FLAPPING_IFACES[@]}"; do
    _past_count=$(awk -F'\t' -v iface="$_ri" '$2 == iface && $3 == "FLAPPING" { c++ } END { print c+0 }' "$EVENT_LOG" 2>/dev/null || echo "0")
    if [[ "$_past_count" -ge 3 ]]; then
      _RECURRING_IFACES["$_ri"]="$_past_count"
      echo -e "  ${YELLOW}${BOLD}[RECURRING]${RESET} ${BOLD}${_ri}${RESET} — ${_past_count} previous flapping events in event log"
      echo -e "  ${DIM}Use --events to review history${RESET}"
      echo ""
    fi
  done
fi

if [[ "$FLAPPING_FOUND" -eq 0 ]]; then
  _thresh_note="threshold: ${FLAP_THRESHOLD} transitions"
  [[ ${#IFACE_THRESHOLDS[@]} -gt 0 ]] && _thresh_note+=" + per-interface overrides"
  echo -e "${GREEN}No flapping detected${RESET} in the last ${WINDOW_MINUTES} minutes (${_thresh_note})."
  echo ""
else
  _plural="s"; [[ "$FLAPPING_COUNT" -eq 1 ]] && _plural=""
  _thresh_note=""
  [[ ${#IFACE_THRESHOLDS[@]} -gt 0 ]] && _thresh_note=" (per-interface thresholds active)"
  echo -e "${BOLD}Summary:${RESET} ${RED}${FLAPPING_COUNT} interface${_plural} flapping${RESET} in the last ${WINDOW_MINUTES} minutes.${_thresh_note}"
  echo ""
fi

# ── Auto-diagnostic wizard ─────────────────────────────────────────────────────
# When flapping is found and no explicit -d was given, automatically run the
# diagnostic wizard on each flapping interface so the user gets actionable
# findings in a single command.
# Skipped in test mode (_LINK_FLAP_TEST_INPUT / _LINK_FLAP_TEST_TSHARK set)
# unless _LINK_FLAP_TEST_WIZARD_DIR is also provided for mocked sysfs.
if [[ ${#FLAPPING_IFACES[@]} -gt 0 ]] && {
     [[ -z "${_LINK_FLAP_TEST_INPUT:-}" && -z "${_LINK_FLAP_TEST_TSHARK:-}" ]] ||
     [[ -n "${_LINK_FLAP_TEST_WIZARD_DIR:-}" ]]; }; then
  for _auto_iface in "${FLAPPING_IFACES[@]}"; do
    echo -e "${BOLD}──── Diagnostic: ${CYAN}${_auto_iface}${RESET}${BOLD} ────${RESET}"
    echo ""
    run_wizard "$_auto_iface"
  done
fi

# ── Webhook state-change alerts ───────────────────────────────────────────────
_FLAP_NEXT_FLAPPING=""
if [[ -n "$WEBHOOK_URL" ]]; then
  declare -A _prev_flapping_set=()
  for _pi in ${_FLAP_PREV_FLAPPING:-}; do
    _prev_flapping_set["$_pi"]=1
  done

  for _wi in "${FLAPPING_IFACES[@]}"; do
    if [[ -z "${_prev_flapping_set[$_wi]:-}" ]]; then
      _send_webhook "$WEBHOOK_URL" "flapping" "$_wi" "${FLAPPING_TRANSITIONS[$_wi]:-}"
    fi
  done

  if [[ -n "$FOLLOW_SECONDS" ]]; then
    declare -A _curr_flapping_set=()
    for _wi in "${FLAPPING_IFACES[@]}"; do _curr_flapping_set["$_wi"]=1; done
    for _pi in "${!_prev_flapping_set[@]}"; do
      if [[ -z "${_curr_flapping_set[$_pi]:-}" ]]; then
        _send_webhook "$WEBHOOK_URL" "cleared" "$_pi"
      fi
    done
  fi

  _FLAP_NEXT_FLAPPING="${FLAPPING_IFACES[*]:-}"
fi

# ── Persistent event log ────────────────────────────────────────────────────
# Append FLAPPING / CLEARED entries to the event log for historical queries.
# Skipped in test mode unless EVENT_LOG is explicitly overridden.
if [[ -z "${_LINK_FLAP_TEST_INPUT:-}" ]] || [[ "${EVENT_LOG}" == */test-* ]]; then
  _el_ts=$(date -u "+%Y-%m-%dT%H:%M:%S+0000")
  mkdir -p "$(dirname "$EVENT_LOG")"
  (
    flock -n 200 || {
      echo "Warning: event log locked, skipping write." >&2
      exit 0   # exits subshell only
    }
    for _el_iface in "${FLAPPING_IFACES[@]}"; do
      _el_t="${FLAPPING_TRANSITIONS[$_el_iface]:-0}"
      printf '%s\t%s\tFLAPPING\ttransitions=%s\n' "$_el_ts" "$_el_iface" "$_el_t" >> "$EVENT_LOG"
    done
  ) 200>>"$EVENT_LOG"

  # Rotate event log: keep last 10,000 lines
  if [[ -f "$EVENT_LOG" ]] && (( $(wc -l < "$EVENT_LOG") > 10000 )); then
    tail -n 10000 "$EVENT_LOG" > "${EVENT_LOG}.tmp" \
      && mv "${EVENT_LOG}.tmp" "$EVENT_LOG"
  fi

  # Prune reports older than 90 days
  [[ -d "${REPORT_DIR:-}" ]] && \
    find "$REPORT_DIR" -name '*.txt' -mtime +90 -delete 2>/dev/null || true
fi

# ── Prometheus textfile export (--export) ────────────────────────────────────
if [[ -n "$EXPORT_FILE" ]]; then
  {
    echo "# HELP link_flap_is_flapping Whether the interface is currently flapping (1=yes, 0=no)."
    echo "# TYPE link_flap_is_flapping gauge"
    echo "# HELP link_flap_transitions_total Number of link state transitions detected in the scan window."
    echo "# TYPE link_flap_transitions_total gauge"
    echo "# HELP link_flap_last_scan_timestamp Unix timestamp of the last scan."
    echo "# TYPE link_flap_last_scan_timestamp gauge"
    for _ex_iface in "${FLAPPING_IFACES[@]+"${FLAPPING_IFACES[@]}"}"; do
      echo "link_flap_is_flapping{interface=\"${_ex_iface}\"} 1"
      echo "link_flap_transitions_total{interface=\"${_ex_iface}\"} ${FLAPPING_TRANSITIONS[$_ex_iface]:-0}"
    done
    echo "link_flap_last_scan_timestamp $(date +%s)"
  } > "$EXPORT_FILE"
fi

if [[ -n "$FOLLOW_SECONDS" ]]; then
  # Build transition counts for next cycle's deduplication
  _FLAP_NEXT_TRANSITIONS=""
  for _ti in "${FLAPPING_IFACES[@]}"; do
    [[ -n "$_FLAP_NEXT_TRANSITIONS" ]] && _FLAP_NEXT_TRANSITIONS+=","
    _FLAP_NEXT_TRANSITIONS+="${_ti}=${FLAPPING_TRANSITIONS[$_ti]}"
  done
  # Always pass the current flapping list (even without webhooks)
  [[ -z "${_FLAP_NEXT_FLAPPING:-}" ]] && _FLAP_NEXT_FLAPPING="${FLAPPING_IFACES[*]:-}"
  echo -e "${DIM}--- next scan in ${FOLLOW_SECONDS}s (Ctrl-C to stop) ---${RESET}"
  sleep "$FOLLOW_SECONDS"
  [[ "$_SHUTTING_DOWN" -eq 1 ]] && exit 0
  exec env _FLAP_FOLLOW_CHILD=1 \
    _FLAP_PREV_FLAPPING="${_FLAP_NEXT_FLAPPING:-}" \
    _FLAP_PREV_TRANSITIONS="${_FLAP_NEXT_TRANSITIONS:-}" \
    "$0" "${_ORIG_ARGS[@]}"
fi
# ── JSON output emission ─────────────────────────────────────────────────────
if [[ "$JSON_MODE" -eq 1 ]]; then
  exec 1>&3  # restore real stdout
  _j_ifaces_arr=""
  for _ji in "${_JSON_IFACES[@]+"${_JSON_IFACES[@]}"}"; do
    [[ -n "$_j_ifaces_arr" ]] && _j_ifaces_arr+=","
    _j_ifaces_arr+="$_ji"
  done
  _j_flapping_arr=""
  for _jf in "${FLAPPING_IFACES[@]+"${FLAPPING_IFACES[@]}"}"; do
    [[ -n "$_j_flapping_arr" ]] && _j_flapping_arr+=","
    _j_flapping_arr+="\"${_jf}\""
  done
  _j_corr="false"
  [[ "$_JSON_CORRELATION" == "true" ]] && _j_corr="true"
  _j_flap_found="false"
  [[ "$FLAPPING_FOUND" -eq 1 ]] && _j_flap_found="true"
  _emit_json "$_j_ifaces_arr" "$_j_corr" "$_j_flap_found" "$FLAPPING_COUNT" "$_j_flapping_arr"
  exit $(( FLAPPING_FOUND ))
fi

_flap_what_next "$(( FLAPPING_FOUND ))"
exit $(( FLAPPING_FOUND ))
