  echo "$_NE_METRICS_CACHE" | awk -v m="$metric" -v d="$iface" '
    /^#/ { next }
    index($0, m "{") == 1 && index($0, "device=\"" d "\"") { print $NF; exit }
  ' 2>/dev/null || true
}

